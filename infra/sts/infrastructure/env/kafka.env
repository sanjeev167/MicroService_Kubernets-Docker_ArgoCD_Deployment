# ==========================================================
#
# PURPOSE
# ----------------------------------------------------------
# Centralized runtime configuration for the Apache Kafka
# Docker container used by the STS infrastructure.
#
# This file contains the native environment variables
# expected by the Confluent Kafka Docker image.
#
# Docker Compose injects these variables directly into the
# Kafka container through:
#
#     env_file:
#       - ./env/kafka.env
#
# This file is the single source of truth for Kafka runtime
# configuration within the STS environment.
#
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# Primary Environment
#
# ✔ Spring Tool Suite (STS)
# ✔ Docker Compose
#
#
# Future Deployment Model
# ----------------------------------------------------------
# The same configuration model is reused for:
#
# ✔ Kubernetes
# ✔ AWS EKS
#
# Environment-specific listener addresses are supplied
# through Kubernetes ConfigMaps, Secrets or deployment
# environment variables without modifying application code.
#
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Single source of truth
# ✔ Native Kafka environment variables
# ✔ STS-specific infrastructure configuration
# ✔ Reusable deployment model
# ✔ Docker Ready
# ✔ Kubernetes Ready
# ✔ AWS Ready
#
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|------------------------------------------
# 1.0.0   | 03-Jul-2026 | Sanjeev Kumar  | Initial configuration.
#
# 1.1.0   | 03-Jul-2026 | Sanjeev Kumar  | Updated to use native Confluent Kafka
#         |             |                | environment variables.
#         |             |                | Finalized and locked as the STS
#         |             |                | infrastructure standard.
#
# ==========================================================


# ==========================================================
# Kafka KRaft Configuration
# ==========================================================
#
# Cluster Identifier
#
# Unique identifier for the Kafka KRaft cluster.
#
# Node Identifier
#
# Unique identifier for this Kafka broker.
#
# Process Roles
#
# Single-node development environment.
#
# The broker acts as both:
#
#   • Kafka Broker
#   • Kafka Controller
#
# Controller Quorum
#
# Defines the controller node(s) participating in the
# KRaft quorum.
#
# ==========================================================

CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NODE_ID=1

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093


# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# PLAINTEXT
# ----------
# Used by Docker containers communicating through the
# shared Docker network.
#
#
# PLAINTEXT_HOST
# --------------
# Used by Spring Boot microservices running directly from
# Spring Tool Suite (STS).
#
#
# CONTROLLER
# ----------
# Internal KRaft controller communication.
#
#
# IMPORTANT
# ----------------------------------------------------------
# PLAINTEXT_HOST advertises the Kafka broker endpoint
# consumed by Spring Boot applications executing from STS.
#
# Therefore:
#
#     localhost
#
# is the correct advertised host for the STS environment.
#
# Do NOT replace localhost with "kafka" for STS.
#
# Kubernetes and AWS deployments override this value
# through their deployment configuration.
#
# ==========================================================

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,PLAINTEXT_HOST://0.0.0.0:29092,CONTROLLER://0.0.0.0:9093

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:29092

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT,CONTROLLER:PLAINTEXT

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER


# ==========================================================
# Kafka Storage Configuration
# ==========================================================
#
# Directory used by Kafka KRaft to store:
#
# • Cluster metadata
# • Broker metadata
# • Topic log segments
#
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs


# ==========================================================
# Kafka Broker Configuration
# ==========================================================
#
# Offset Topic Replication Factor
#
# Single-node Kafka requires a replication factor of one.
#
#
# Auto Topic Creation
#
# Automatically creates topics during local development.
#
# Recommended:
#
# Development : true
# Production  : false
#
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true


