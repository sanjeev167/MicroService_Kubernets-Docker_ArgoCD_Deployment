# ==========================================================
# FILE             : kafka.env
# MODULE           : Apache Kafka Environment Configuration
# PROJECT          : MSIMPL - Microservices Platform
# ENVIRONMENT      : Kubernetes Infrastructure
# AUTHOR           : Sanjeev Kumar
# CREATED ON       : 04-Jul-2026
# LAST MODIFIED    : 07-Jul-2026
# VERSION          : 1.1.0
# ==========================================================
#
# PURPOSE
# ----------------------------------------------------------
# Centralized runtime configuration for the Apache Kafka
# Docker container used by the MSIMPL Kubernetes
# development environment.
#
# Kafka executes inside Docker Desktop while all Spring
# Boot microservices execute inside the local Kubernetes
# cluster.
#
# Docker Compose injects these variables directly into
# the Kafka container through:
#
#     env_file:
#       - ./env/kafka.env
#
# This file is the single source of truth for Kafka
# runtime configuration used during Kubernetes
# development.
#
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
#
# Primary Environment
#
# ✔ Local Kubernetes Cluster
#
# Kafka Runtime
#
# ✔ Docker Desktop
#
# Spring Boot Runtime
#
# ✔ Kubernetes Pods
#
#
# Future Deployment Model
# ----------------------------------------------------------
#
# When Kafka is deployed inside Kubernetes or AWS EKS,
# only the listener addresses need to change.
#
# Application code and Docker images remain unchanged.
#
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
#
# ✔ Single source of truth
# ✔ Native Confluent Kafka environment variables
# ✔ Kubernetes-compatible networking
# ✔ Docker Desktop compatible
# ✔ Reusable deployment model
# ✔ AWS Ready
#
#
# VERSION HISTORY
# ----------------------------------------------------------
#
# Version | Date        | Author         | Description
# --------|-------------|----------------|--------------------------------------------
# 1.0.0   | 04-Jul-2026 | Sanjeev Kumar  | Docker environment configuration.
# 1.1.0   | 07-Jul-2026 | Sanjeev Kumar  | Kubernetes infrastructure configuration
#         |             |                | using Docker-hosted Kafka.
#
# ==========================================================



# ==========================================================
# Kafka KRaft Configuration
# ==========================================================
#
# Cluster Identifier
#
# Unique identifier for the Kafka KRaft cluster.
#
# Node Identifier
#
# Unique identifier for this Kafka broker.
#
# Process Roles
#
# Single-node development environment.
#
# The broker acts as both:
#
# • Kafka Broker
# • Kafka Controller
#
# Controller Quorum
#
# Internal controller communication remains inside
# the Docker container network.
#
# ==========================================================

CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NODE_ID=1

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093



# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# Kubernetes Development Environment
# ----------------------------------------------------------
#
# Kafka executes inside Docker Desktop while the Spring
# Boot microservices execute inside the Kubernetes
# cluster.
#
# Kubernetes Pods cannot resolve Docker container
# hostnames such as:
#
#     kafka
#
# Therefore Kafka advertises the Docker Desktop host
# address instead of the Docker container hostname.
#
# Spring Boot applications connect using:
#
#     host.docker.internal:9092
#
# Kafka UI continues to communicate internally using:
#
#     kafka:9092
#
# ==========================================================

#
# Kafka Listeners
#

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093

#
# Advertised Broker Address
#

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://host.docker.internal:9092

#
# Listener Security Mapping
#

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

#
# Inter-Broker Listener
#

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

#
# Controller Listener
#

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER



# ==========================================================
# Kafka Storage Configuration
# ==========================================================
#
# Directory used by Kafka KRaft to store:
#
# • Cluster metadata
# • Broker metadata
# • Topic log segments
#
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs



# ==========================================================
# Kafka Broker Configuration
# ==========================================================
#
# Offset Topic Replication Factor
#
# Single-node Kafka requires a replication factor of one.
#
#
# Auto Topic Creation
#
# Automatically creates topics during local development.
#
# Recommended:
#
# Development : true
# Production  : false
#
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true



# ==========================================================
# MSIMPL INFRASTRUCTURE STANDARD
# ==========================================================
#
# Status
# ------
# LOCKED
#
# This file is the finalized Apache Kafka runtime
# configuration for the MSIMPL Kubernetes development
# infrastructure.
#
# Kafka executes inside Docker Desktop while the
# following microservices execute inside Kubernetes:
#
# ✔ ms-wallet
# ✔ ms-notification
# ✔ ms-transaction-orchestrator
# ✔ ms-gateway-server
# ✔ ms-auth-server
# ✔ ms-config-server
# ✔ ms-discovery-server
# ✔ Future MSIMPL services
#
# The advertised listener is configured so that
# Kubernetes Pods can communicate with the Docker-
# hosted Kafka broker through:
#
#     host.docker.internal:9092
#
# Changes to this file should only be made when the
# shared Kafka infrastructure changes.
#
# ==========================================================



