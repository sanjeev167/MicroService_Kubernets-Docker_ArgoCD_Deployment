# ==========================================================
# FILE             : transaction-orchestrator.env
# MODULE           : Transaction Orchestrator Docker Environment
# PROJECT          : MSIMPL
# ENVIRONMENT      : Docker
# AUTHOR           : Sanjeev Kumar
# CREATED ON       : 04-Jul-2026
# VERSION          : 1.0.0
# ==========================================================

# ==========================================================
# Docker Image
# ==========================================================

ORCHESTRATOR_IMAGE_NAME=ms-transaction-orchestrator

ORCHESTRATOR_IMAGE_VERSION=0.0.1-SNAPSHOT

# Spring Boot Runtime
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=orchestrator_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ==========================================================
# Kafka Configuration
# ==========================================================

KAFKA_HOST=kafka

KAFKA_PORT=9092

LOG_PATH=./logs

# ==========================================================
# Container Configuration
# ==========================================================

ORCHESTRATOR_CONTAINER_NAME=ms-transaction-orchestrator

ORCHESTRATOR_HOSTNAME=ms-transaction-orchestrator

ORCHESTRATOR_RESTART=unless-stopped


# ==========================================================
# Port Configuration
# ==========================================================

ORCHESTRATOR_PORT=8082


# ==========================================================
# JVM Configuration
# ==========================================================

ORCHESTRATOR_JAVA_OPTS=-Xms256m -Xmx512m