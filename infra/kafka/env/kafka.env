# =============================================================================
# Kafka Environment Configuration
# =============================================================================
# File        : kafka.env
# Project     : MSIMPL - Microservices Platform
# Purpose     : Runtime configuration for the Confluent Kafka Docker container
# Environment : Kubernetes Development Infrastructure
# Version     : 1.1.0
# =============================================================================
#
# Notes
# -----
# - Kafka runs in Docker Desktop.
# - MSIMPL microservices run inside the local Kubernetes cluster.
# - Loaded by docker-compose.yml using env_file.
# - When Kafka is migrated to Kubernetes or AWS, update only the advertised
#   listener address. No application code changes are required.
#
# =============================================================================


# =============================================================================
# KRaft Configuration
# =============================================================================

CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NODE_ID=1

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093


# =============================================================================
# Listener Configuration
# =============================================================================
#
# Kafka executes inside Docker Desktop while the Spring Boot
# microservices execute inside the local Kubernetes cluster.
#
# Kubernetes Pods cannot resolve Docker container hostnames
# (for example: kafka). Therefore Kafka advertises the Docker
# host endpoint so that Kubernetes Pods can connect to the broker.
#
# Current Development Endpoint:
#
#     host.docker.internal:9092
#
# Future Environments:
#
# - Kubernetes : Kafka Service DNS
# - AWS EKS    : Amazon MSK Broker Endpoint
#
# =============================================================================

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://host.docker.internal:9092

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER


# =============================================================================
# Storage Configuration
# =============================================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs


# =============================================================================
# Broker Configuration
# =============================================================================
#
# Auto topic creation is enabled for local development.
# Disable this setting in production environments.
#
# =============================================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true


# =============================================================================
# Status
# =============================================================================
#
# LOCKED
#
# Shared Kafka runtime configuration for the MSIMPL Kubernetes
# development environment.
#
# This configuration has been validated with:
#
# - Kafka running in Docker Desktop
# - Spring Boot microservices running in Kind Kubernetes
#
# Update this file only when Kafka infrastructure or broker
# networking changes.
#
# =============================================================================