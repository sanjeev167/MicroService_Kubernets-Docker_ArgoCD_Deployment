# ==========================================================
# FILE             : kafka.env
# MODULE           : Apache Kafka Environment Configuration
# PROJECT          : MSIMPL - Microservices Platform
# ENVIRONMENT      : Docker
# AUTHOR           : Sanjeev Kumar
# CREATED ON       : 04-Jul-2026
# LAST MODIFIED    : 04-Jul-2026
# VERSION          : 1.0.0
# ==========================================================
#
# PURPOSE
# ----------------------------------------------------------
# Centralized runtime configuration for the Apache Kafka
# Docker container used by the Docker infrastructure.
#
# This file contains the native environment variables
# expected by the Confluent Kafka Docker image.
#
# Docker Compose injects these variables directly into the
# Kafka container through:
#
#     env_file:
#       - ./env/kafka.env
#
# This file is the single source of truth for Kafka runtime
# configuration within the Docker environment.
#
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# Primary Environment
#
# ✔ Docker
#
#
# Future Deployment Model
# ----------------------------------------------------------
# The same configuration model is reused for:
#
# ✔ Kubernetes
# ✔ AWS EKS
#
# Environment-specific listener addresses are supplied
# through Kubernetes ConfigMaps, Secrets or deployment
# environment variables without modifying application code.
#
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Single source of truth
# ✔ Native Confluent Kafka environment variables
# ✔ Docker-specific infrastructure configuration
# ✔ Reusable deployment model
# ✔ Kubernetes Ready
# ✔ AWS Ready
#
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|------------------------------------------
# 1.0.0   | 04-Jul-2026 | Sanjeev Kumar  | Docker environment configuration derived
#         |             |                | from the finalized STS infrastructure.
#
# ==========================================================


# ==========================================================
# Kafka KRaft Configuration
# ==========================================================
#
# Cluster Identifier
#
# Unique identifier for the Kafka KRaft cluster.
#
# Node Identifier
#
# Unique identifier for this Kafka broker.
#
# Process Roles
#
# Single-node development environment.
#
# The broker acts as both:
#
#   • Kafka Broker
#   • Kafka Controller
#
# Controller Quorum
#
# Defines the controller node(s) participating in the
# KRaft quorum.
#
# ==========================================================

CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NODE_ID=1

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093


# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# Docker Environment
# ----------------------------------------------------------
#
# All MSIMPL microservices execute inside Docker
# containers connected to the shared Docker bridge network.
#
# Therefore every microservice connects to Kafka using:
#
#     kafka:9092
#
# No host listener is required because no Spring Boot
# application executes outside Docker in this environment.
#
# ==========================================================

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER


# ==========================================================
# Kafka Storage Configuration
# ==========================================================
#
# Directory used by Kafka KRaft to store:
#
# • Cluster metadata
# • Broker metadata
# • Topic log segments
#
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs


# ==========================================================
# Kafka Broker Configuration
# ==========================================================
#
# Offset Topic Replication Factor
#
# Single-node Kafka requires a replication factor of one.
#
#
# Auto Topic Creation
#
# Automatically creates topics during local development.
#
# Recommended:
#
# Development : true
# Production  : false
#
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true


# ==========================================================
# MSIMPL INFRASTRUCTURE STANDARD
# ==========================================================
#
# Status
# ------
# LOCKED
#
# This file is the finalized Apache Kafka runtime
# configuration for the Docker infrastructure.
#
# It is shared by all MSIMPL microservices executing
# inside Docker containers.
#
# Microservices using this infrastructure include:
#
# ✔ ms-wallet
# ✔ ms-notification
# ✔ ms-transaction-orchestrator
# ✔ ms-gateway-server
# ✔ ms-auth-server
# ✔ ms-config-server
# ✔ ms-discovery-server
# ✔ Future MSIMPL services
#
# Changes to this file should only be made when the shared
# Docker infrastructure itself changes.
#
# ==========================================================


