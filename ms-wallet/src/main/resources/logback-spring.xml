==============================================================================
PURPOSE
==============================================================================
Centralized Logback configuration for the MS Wallet Service.

Provides:

✔ Console Logging
✔ Rolling File Logging
✔ Promtail Integration
✔ Loki Integration
✔ Grafana Log Visualization
✔ Distributed Request Tracing

The same logging configuration is used across all deployment
environments.

Only the log storage location changes through environment
variables.

==============================================================================
LOGGING ARCHITECTURE
==============================================================================

            Spring Boot Application
                     │
                     ▼
                  Logback
             ┌────────┴────────┐
             │                 │
             ▼                 ▼
      Console Output      Rolling Log File
                                   │
                                   ▼
                               Promtail
                                   │
                                   ▼
                                  Loki
                                   │
                                   ▼
                                Grafana

==============================================================================
ENVIRONMENT SUPPORT
==============================================================================

Spring Tool Suite (STS)
==============================================================================

LOG_PATH defaults to:

    ../logs

Log files are stored outside the project directory.


Docker Compose
==============================================================================

Override:

    LOG_PATH=/var/log/app

Promtail mounts this directory and forwards logs to Loki.


Kubernetes
==============================================================================

Override:

    LOG_PATH=/var/log/app

The directory is typically backed by a mounted volume.


AWS EKS
==============================================================================

Override:

    LOG_PATH=/var/log/app

Logs may be collected by Promtail, Fluent Bit or another
centralized logging solution.


==============================================================================
MSIMPL DEPLOYMENT STANDARD
==============================================================================

✔ STS Ready
✔ Docker Ready
✔ Kubernetes Ready
✔ AWS EKS Ready
✔ Loki Ready
✔ Promtail Ready

Same application code.

Same executable JAR.

Same Docker image.

Same Logback configuration.

Only environment variables change.

==============================================================================
-->

<configuration>

    <!-- ================================================================== -->
    <!-- APPLICATION NAME                                                   -->
    <!-- ================================================================== -->

    <springProperty
            scope="context"
            name="appName"
            source="spring.application.name"/>

    <!-- ================================================================== -->
    <!-- LOG DIRECTORY                                                      -->
    <!-- ================================================================== -->
    <!--
         Default:
             ../logs

         Override using:

             LOG_PATH=/var/log/app

         for Docker, Kubernetes or AWS.
    -->

    <property
            name="LOG_PATH"
            value="${LOG_PATH:-../logs}"/>

    <!-- ================================================================== -->
    <!-- LOG FILE                                                           -->
    <!-- ================================================================== -->

    <property
            name="LOG_FILE"
            value="${LOG_PATH}/${appName}.log"/>

    <!-- ================================================================== -->
    <!-- LOG PATTERN                                                        -->
    <!-- ================================================================== -->

    <property
            name="LOG_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [service=${appName}] [traceId=%X{traceId}] [txnId=%X{txnId}] - %msg%n"/>

    <!-- ================================================================== -->
    <!-- CONSOLE APPENDER                                                   -->
    <!-- ================================================================== -->

    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>

    </appender>

    <!-- ================================================================== -->
    <!-- ROLLING FILE APPENDER                                              -->
    <!-- ================================================================== -->
    <!--
         Required for Promtail.

         Loki never reads log files directly.

         Promtail continuously monitors this directory
         and forwards logs to Loki.
    -->

    <appender name="FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_FILE}</file>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <fileNamePattern>
                ${LOG_PATH}/${appName}.%d{yyyy-MM-dd}.%i.log
            </fileNamePattern>

            <!-- Maximum file size before rollover -->

            <maxFileSize>50MB</maxFileSize>

            <!-- Keep logs for seven days -->

            <maxHistory>7</maxHistory>

            <!-- Maximum total disk usage -->

            <totalSizeCap>2GB</totalSizeCap>

        </rollingPolicy>

        <encoder>

            <pattern>${LOG_PATTERN}</pattern>

        </encoder>

    </appender>

    <!-- ================================================================== -->
    <!-- ROOT LOGGER                                                        -->
    <!-- ================================================================== -->

    <root level="INFO">

        <appender-ref ref="CONSOLE"/>

        <appender-ref ref="FILE"/>

    </root>

    <!-- ================================================================== -->
    <!-- PACKAGE LEVEL LOGGING                                              -->
    <!-- ================================================================== -->

    <logger name="org.springframework" level="WARN"/>

    <logger name="org.apache.kafka" level="WARN"/>

</configuration>