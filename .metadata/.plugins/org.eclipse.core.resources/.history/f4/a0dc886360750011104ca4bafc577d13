# ==========================================================
# DOCKER COMPOSE CONFIGURATION (INFRA STACK)
# ==========================================================
# Author: Sanjeev
# Date: 19-June-2026
# Version: 3.8
#
# PURPOSE:
# ----------------------------------------------------------
# * Provides core infrastructure for MSIMPL platform
# * Includes:
#     - Kafka (Event Streaming)
#     - Kafka UI (Monitoring)
#     - Prometheus (Metrics Collection)
#     - Grafana (Visualization Layer)
#
# * Integrates with Logging Stack:
#     Promtail → Loki → Grafana
#
# OBSERVABILITY ARCHITECTURE:
# ----------------------------------------------------------
# Metrics:   Microservices → Prometheus → Grafana
# Logs:      Microservices → Promtail → Loki → Grafana
#
# NETWORK STRATEGY:
# ----------------------------------------------------------
# ✔ Single shared network: infra_msimpl-network
# ✔ Used across:
#     - Logging stack (Loki, Promtail)
#     - Infra stack (Grafana, Prometheus)
#
# ✔ Enables service discovery using container names:
#     http://loki:3100
#     http://prometheus:9090
#
# ==========================================================

version: '3.8'

services:

  # ==========================================================
  # 🟡 KAFKA (KRaft Mode - Single Node)
  # ==========================================================
  kafka:
    image: confluentinc/cp-kafka:7.5.0
    container_name: kafka

    ports:
      - "9092:9092"       # Internal communication
      - "29092:29092"     # External (localhost)

    environment:
      # -----------------------------
      # KRaft Mode Configuration
      # -----------------------------
      CLUSTER_ID: "MkU3OEVBNTcwNTJENDM2Qk"
      KAFKA_PROCESS_ROLES: "broker,controller"
      KAFKA_NODE_ID: 1
      KAFKA_CONTROLLER_QUORUM_VOTERS: "1@kafka:9093"

      # -----------------------------
      # Listener Configuration
      # -----------------------------
      KAFKA_LISTENERS: >
        PLAINTEXT://0.0.0.0:9092,
        PLAINTEXT_HOST://0.0.0.0:29092,
        CONTROLLER://0.0.0.0:9093

      KAFKA_ADVERTISED_LISTENERS: >
        PLAINTEXT://kafka:9092,
        PLAINTEXT_HOST://localhost:29092

      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: >
        PLAINTEXT:PLAINTEXT,
        PLAINTEXT_HOST:PLAINTEXT,
        CONTROLLER:PLAINTEXT

      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER

      # -----------------------------
      # Storage & Dev Config
      # -----------------------------
      KAFKA_LOG_DIRS: "/tmp/kraft-combined-logs"
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: "true"

    networks:
      - infra_msimpl-network

    restart: always


  # ==========================================================
  # 🟠 KAFKA UI (Cluster Monitoring)
  # ==========================================================
  kafka-ui:
    image: provectuslabs/kafka-ui
    container_name: kafka-ui

    ports:
      - "8085:8080"

    environment:
      KAFKA_CLUSTERS_0_NAME: local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092

    depends_on:
      - kafka

    networks:
      - infra_msimpl-network

    restart: always


  # ==========================================================
  # 🟢 PROMETHEUS (Metrics Collector)
  # ==========================================================
  prometheus:
    image: prom/prometheus
    container_name: prometheus

    ports:
      - "9090:9090"

    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml

    # --------------------------------------------------------
    # 🔴 CRITICAL:
    # Must be in SAME network as Grafana
    # --------------------------------------------------------
    networks:
      - infra_msimpl-network

    depends_on:
      - kafka

    restart: always


  # ==========================================================
  # 🔵 GRAFANA (Visualization Layer)
  # ==========================================================
  grafana:
    image: grafana/grafana
    container_name: grafana

    ports:
      - "3000:3000"

    volumes:
      - grafana-storage:/var/lib/grafana

    depends_on:
      - prometheus

    # --------------------------------------------------------
    # 🔴 CRITICAL:
    # Same network as Loki + Prometheus
    # --------------------------------------------------------
    networks:
      - infra_msimpl-network

    restart: always


# ==========================================================
# 🔹 NETWORK CONFIGURATION
# ==========================================================
# Shared with logging stack:
# docker-compose-logs.yml
# ==========================================================
networks:
  infra_msimpl-network:
    external: true


# ==========================================================
# 🔹 VOLUMES
# ==========================================================
volumes:
  grafana-storage: