# PURPOSE
# ----------------------------------------------------------
# Centralized runtime configuration for the Apache Kafka
# Docker container used by the Docker infrastructure.
#
# This file contains the native environment variables
# expected by the Confluent Kafka Docker image.
#
# Docker Compose injects these variables directly into the
# Kafka container through:
#
#     env_file:
#       - ./env/kafka.env
#
# ==========================================================



# ==========================================================
# Kafka KRaft Configuration
# ==========================================================

CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NODE_ID=1

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093



# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# Docker Environment
# ------------------
#
# All MSIMPL microservices execute inside Docker containers.
#
# Therefore every service communicates with Kafka using
#
#     kafka:9092
#
# The STS-specific PLAINTEXT_HOST listener is NOT required.
#
# ==========================================================

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER



# ==========================================================
# Kafka Storage Configuration
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs



# ==========================================================
# Kafka Broker Configuration
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true



# ==========================================================
# Docker Infrastructure Standard
# ==========================================================
#
# This configuration is used by:
#
# ✔ Kafka
# ✔ Wallet Service
# ✔ Notification Service
# ✔ Transaction Orchestrator
# ✔ Gateway
# ✔ Future MSIMPL Microservices
#
# All containers communicate with Kafka using:
#
#     kafka:9092
#
# ==========================================================