# ==========================================================
# PROMTAIL CONFIGURATION (MSIMPL LOG COLLECTION AGENT)
# ==========================================================
# Author: Sanjeev
# Date: 20-June-2026
# Version: v2 (Enhanced)
#
# PURPOSE:
# * Collect logs from centralized logs directory (outside services)
# * Push logs to Loki
# * Enable service-level observability in Grafana
#
# LOG FLOW:
# ----------------------------------------------------------
# logs/*.log → Promtail → Loki → Grafana
#
# DESIGN PRINCIPLES:
# ✔ Centralized logs (outside microservices)
# ✔ No tight coupling with service code
# ✔ Lightweight log shipping
# ✔ Service identification via filename (no code dependency)
#
# IMPORTANT:
# ----------------------------------------------------------
# Docker Volume Mapping:
#   Host logs folder → /var/log/app (inside container)
#
# Example:
#   ../logs:/var/log/app
#
# Log File Naming Convention:
#   ms-wallet.log
#   ms-notification.log
#   ms-orchestrator.log
#
# This naming enables automatic service labeling.
# ==========================================================


# ==========================================================
# SERVER CONFIGURATION
# ==========================================================
server:
  http_listen_port: 9080


# ==========================================================
# POSITION TRACKING (OFFSET MANAGEMENT)
# ==========================================================
# Tracks last read position to avoid duplicate ingestion
positions:
  filename: /tmp/positions.yaml


# ==========================================================
# LOKI CLIENT CONFIGURATION
# ==========================================================
clients:
  - url: http://loki:3100/loki/api/v1/push


# ==========================================================
# SCRAPE CONFIGURATION
# ==========================================================
scrape_configs:

  # ========================================================
  # SPRING BOOT MICROSERVICE LOGS
  # ========================================================
  - job_name: spring-boot-logs

    static_configs:
      - targets:
          - localhost

        labels:
          # Logical grouping (used in Grafana queries)
          job: msimpl

          # Environment label
          env: local

          # Log type classification
          type: application

          # --------------------------------------------------
          # Log file path INSIDE container
          # MUST match Docker volume mapping
          # --------------------------------------------------
          __path__: /var/log/app/*.log


    # ======================================================
    # PIPELINE STAGES (SERVICE AUTO-DETECTION)
    # ======================================================
    # Extract service name from log filename
    # Example:
    #   /var/log/app/ms-wallet.log → service=ms-wallet
    #
    pipeline_stages:

      - regex:
          expression: '.*/(?P<service>[^/]+)\.log'

      - labels:
          service:


# ==========================================================
# GRAFANA QUERY EXAMPLES
# ==========================================================
#
# ✔ All logs:
#   {job="msimpl"}
#
# ✔ Specific service:
#   {job="msimpl", service="ms-wallet"}
#
# ✔ Error logs:
#   {job="msimpl"} |= "ERROR"
#
# ✔ Transaction tracing:
#   {job="msimpl"} |= "txnId=123"
#
# ✔ Combine filters:
#   {job="msimpl", service="ms-wallet"} |= "FAILED"
#
# ==========================================================


# ==========================================================
# DEBUG / VERIFICATION STEPS
# ==========================================================
#
# ✔ Step 1: Verify logs exist on host
#   ls ../logs
#
# ✔ Step 2: Verify logs inside container
#   docker exec -it promtail sh
#   ls /var/log/app
#
# ✔ Step 3: Check Promtail logs
#   docker logs promtail
#
#   Look for:
#     "tailing new file"
#
# ✔ Step 4: Verify Loki ingestion
#   docker logs loki
#
# ✔ Step 5: Query in Grafana
#   {job="msimpl"}
#
# ==========================================================