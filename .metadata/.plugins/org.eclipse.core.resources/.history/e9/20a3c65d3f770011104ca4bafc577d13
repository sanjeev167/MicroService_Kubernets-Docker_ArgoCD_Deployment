# =============================================================================
# WALLET SERVICE
# =============================================================================

  ms-wallet:

    image: ms-wallet:1.0

    container_name: ms-wallet

    hostname: ms-wallet

    ports:
      - "8080:8080"

    env_file:
      - ./env/wallet.env

    # Future Startup Dependency
    # Uncomment after enabling infrastructure services.
    #
    # depends_on:
    #   - ms-config-server
    #   - ms-discovery-server
    #   - ms-auth-server

    restart: unless-stopped

    networks:
      - infra_msimpl-network



# =============================================================================
# NOTIFICATION SERVICE
# =============================================================================

  ms-notification:

    image: ms-notification:1.0

    container_name: ms-notification

    hostname: ms-notification

    ports:
      - "8081:8081"

    env_file:
      - ./env/notification.env

    # Future Startup Dependency
    #
    # depends_on:
    #   - ms-config-server
