# ==========================================================
# Service Configuration
# Service : ms-wallet
# File    : application.yml
# Author  : Sanjeev Kumar
# Date    : 2026-06-30
#
# Description
# -----------
# This is the bootstrap configuration file for ms-wallet.
#
# Responsibilities
# ----------------
# ✔ Service Identification
# ✔ Server Configuration
# ✔ Import Modular Configuration Files
# ✔ JPA / Hibernate Configuration
#
# Design Principle
# ----------------
# Keep this file minimal.
#
# All external infrastructure configurations such as
#
#   - Database
#   - Kafka
#   - Redis
#   - Security
#   - Service URLs
#   - Observability
#
# are maintained in dedicated configuration files.
#
# Benefits
# --------
# ✔ Easy maintenance
# ✔ Docker Ready
# ✔ Kubernetes Ready
# ✔ AWS Ready
# ✔ Future Spring Cloud Config Ready
#
# ==========================================================

server:
  port: 8080

spring:

  # ========================================================
  # Application Information
  # ========================================================

  application:
    name: ms-wallet

  # ========================================================
  # Modular Configuration Import
  # ========================================================

  config:
    import:
      - classpath:config/application-db.yml
      - classpath:config/application-kafka.yml
     # - classpath:config/application-redis.yml
     # - classpath:config/application-security.yml
     # - classpath:config/application-service.yml
      - classpath:config/application-observability.yml

  # ========================================================
  # JPA / Hibernate Configuration
  # ========================================================

  jpa:

    hibernate:
      ddl-auto: update      # ⚠ Use validate in Production

    show-sql: true          # ⚠ Disable in Production

# ==========================================================
# End Of File
# ==========================================================