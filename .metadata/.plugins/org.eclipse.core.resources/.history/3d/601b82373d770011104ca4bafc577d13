NOTIFICATION_IMAGE_NAME=ms-notification

NOTIFICATION_IMAGE_VERSION=0.0.1-SNAPSHOT

# Spring Boot Runtime
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=notification_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
LOG_PATH=/logs
# ==========================================================
# Container Configuration
# ==========================================================

NOTIFICATION_CONTAINER_NAME=ms-notification

NOTIFICATION_HOSTNAME=ms-notification

NOTIFICATION_RESTART=unless-stopped


# ==========================================================
# Port Configuration
# ==========================================================

NOTIFICATION_PORT=8081


# ==========================================================
# JVM Configuration
# ==========================================================

NOTIFICATION_JAVA_OPTS=-Xms256m -Xmx512m