# ==========================================================
# PROMTAIL CONFIGURATION (LOG COLLECTION AGENT)
# ==========================================================
# Author: Sanjeev
# Date: 19-June-2026
#
# PURPOSE:
# * Collect logs from local filesystem
# * Push logs to Loki for indexing and querying
# * Enable centralized logging for microservices
#
# ROLE IN ARCHITECTURE:
# ----------------------------------------------------------
# Promtail acts as a log shipper (similar to Filebeat)
#
# FLOW:
# logs/*.log → Promtail → Loki → Grafana
#
# DESIGN PRINCIPLES:
# ✔ Lightweight log collection
# ✔ No parsing at source (raw logs)
# ✔ Centralized log ingestion
# ✔ Label-based querying in Grafana
# ==========================================================

# ==========================================================
# SERVER CONFIGURATION
# ==========================================================
server:
  # Port for Promtail internal metrics (optional monitoring)
  http_listen_port: 9080

# ==========================================================
# POSITION TRACKING
# ==========================================================
positions:
  # Stores last read position of log files
  # Prevents re-reading logs after restart
  filename: /tmp/positions.yaml

# ==========================================================
# LOKI CLIENT CONFIGURATION
# ==========================================================
clients:
  - url: http://loki:3100/loki/api/v1/push
    # NOTE:
    # ✔ Use "loki:3100" (container-to-container communication)
    # ✔ Avoid host.docker.internal for better reliability

# ==========================================================
# SCRAPE CONFIGURATION (LOG SOURCES)
# ==========================================================
scrape_configs:

  # ==========================================================
  # 🟢 SPRING BOOT MICROSERVICES LOGS
  # ==========================================================
  - job_name: spring-boot-logs
    static_configs:
      - targets:
          - localhost
        labels:
          # --------------------------------------------------
          # Label used in Grafana queries
          # --------------------------------------------------
          job: msimpl

          # --------------------------------------------------
          # Log file path INSIDE container
          # --------------------------------------------------
          __path__: /var/log/app/*.log

          # --------------------------------------------------
          # Optional labels (recommended for filtering)
          # --------------------------------------------------
          env: local
          type: application

# ==========================================================
# NOTES:
# ==========================================================
# ✔ /var/log/app is mapped from:
#   ../logs (host machine)
#
# ✔ Ensure:
#   - logs folder exists
#   - logs/*.log files are being written by services
#
# ✔ Verify Promtail:
#   docker logs promtail
#
# ✔ Verify logs in Grafana:
#   Explore → Loki → {job="msimpl"}
#
# ✔ Filter by transaction:
#   {job="msimpl"} |= "txnId=123"
# ==========================================================
