# PURPOSE
# ----------------------------------------------------------
# Centralized environment configuration for the PostgreSQL
# Docker container used in the local STS development
# environment.
#
# This file externalizes PostgreSQL-specific configuration
# used by Docker Compose, allowing infrastructure settings
# to remain separate from container definitions. The same
# configuration approach can be reused in Kubernetes and
# cloud deployments through ConfigMaps and Secrets.
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# Primary Environment
# ✔ Spring Tool Suite (STS)
# ✔ Local Docker Compose
#
# Future Deployment Targets
# ----------------------------------------------------------
# ✔ Kubernetes
# ✔ AWS EKS
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Centralized infrastructure configuration
# ✔ Environment-specific configuration
# ✔ Reusable across deployment environments
# ✔ Single source of truth for PostgreSQL configuration
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|--------------------------------------------
# 1.0.0   | 03-Jul-2026 | Sanjeev Kumar  | Initial PostgreSQL environment configuration.
#
# ==========================================================


# ==========================================================
# PostgreSQL Database Configuration
# ==========================================================
#
# Database Name
# Default database created during container initialization.
#
# Database User
# Administrative user created during container startup.
#
# Database Password
# Password assigned to the PostgreSQL administrative user.
#
# ==========================================================

POSTGRES_DB=wallet_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres


# ==========================================================
# PostgreSQL Storage Configuration
# ==========================================================
#
# PostgreSQL Data Directory
# Directory inside the container where PostgreSQL stores
# database files, transaction logs, and internal metadata.
#
# Docker volume mapping ensures that database data remains
# persistent even if the container is recreated.
#
# ==========================================================

PGDATA=/var/lib/postgresql/data


