# =============================================================================
# File Name   : kafka.env
# Module      : Kafka Infrastructure Configuration
# Environment : Docker
# Project     : Microservices Platform (MSIMPL)
# Author      : Sanjeev Kumar
# Created On  : 04-Jul-2026
# =============================================================================
#
# Description
# -----------
# This file contains the Docker infrastructure configuration for Apache Kafka
# running in KRaft mode.
#
# It is used exclusively by Docker Compose and is independent of the Spring
# Boot application configuration.
#
# =============================================================================


# =============================================================================
# Kafka Image Configuration
# =============================================================================

KAFKA_IMAGE_NAME=apache/kafka
KAFKA_IMAGE_VERSION=4.1.0


# =============================================================================
# Kafka Container Configuration
# =============================================================================

KAFKA_CONTAINER_NAME=kafka
KAFKA_HOSTNAME=kafka
KAFKA_RESTART=unless-stopped


# =============================================================================
# Kafka Port Configuration
# =============================================================================

# Internal Kafka Broker Port
KAFKA_INTERNAL_PORT=9092

# Kafka Controller Port (KRaft)
KAFKA_CONTROLLER_PORT=9093

# External Port Exposed to Host
KAFKA_EXTERNAL_PORT=29092


# =============================================================================
# Kafka KRaft Configuration
# =============================================================================

KAFKA_NODE_ID=1

KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM=1@kafka:9093


# =============================================================================
# Kafka Listener Configuration
# =============================================================================

KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT


# =============================================================================
# Kafka Storage Configuration
# =============================================================================

KAFKA_LOG_DIRS=/var/lib/kafka/data


# =============================================================================
# Kafka JVM Configuration
# =============================================================================

KAFKA_HEAP_OPTS=-Xms512m -Xmx512m


# =============================================================================
# Kafka Logging Configuration
# =============================================================================

KAFKA_LOG_LEVEL=INFO