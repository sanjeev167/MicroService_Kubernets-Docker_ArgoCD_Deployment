<!-- ==========================================================
     LOGGING CONFIGURATION (LOGBACK - FINAL CLEAN VERSION)
     ==========================================================
     AUTHOR: Sanjeev Kumar
     DATE:   June 16, 2026

     PURPOSE:
     - Centralized logging for microservices
     - Enable traceability using traceId + txnId (MDC)
     - Support observability via Loki (Promtail reads files)

     KEY DESIGN:
     ✔ Console logs → Developer visibility
     ✔ File logs → Required for Promtail → Loki
     ✔ MDC fields → traceId + txnId for tracing
     ✔ Simple + maintainable config

========================================================== -->

<configuration>

```
<!-- ===================================================== -->
<!-- APPLICATION NAME -->
<!-- ===================================================== -->
<springProperty scope="context" name="appName" source="spring.application.name"/>

<!-- ===================================================== -->
<!-- LOG FILE LOCATION -->
<!-- ===================================================== -->
<property name="LOG_FILE" value="../logs/${appName}.log"/>

<!-- ===================================================== -->
<!-- LOG PATTERN -->
<!-- ===================================================== -->
<property name="LOG_PATTERN"
          value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [service=${appName}] [traceId=%X{traceId}] [txnId=%X{txnId}] - %msg%n"/>

<!-- ===================================================== -->
<!-- CONSOLE APPENDER -->
<!-- ===================================================== -->
<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
        <pattern>${LOG_PATTERN}</pattern>
    </encoder>
</appender>

<!-- ===================================================== -->
<!-- FILE APPENDER (REQUIRED FOR LOKI) -->
<!-- ===================================================== -->
<appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">

    <file>${LOG_FILE}</file>

    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>logs/${appName}.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>7</maxHistory>
    </rollingPolicy>

    <encoder>
        <pattern>${LOG_PATTERN}</pattern>
    </encoder>

</appender>

<!-- ===================================================== -->
<!-- ROOT LOGGER -->
<!-- ===================================================== -->
<root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="FILE"/>
</root>

<!-- ===================================================== -->
<!-- PACKAGE LEVEL LOGGING (NOISE CONTROL) -->
<!-- ===================================================== -->
<logger name="org.springframework" level="WARN"/>
<logger name="org.apache.kafka" level="WARN"/>
```

</configuration>
