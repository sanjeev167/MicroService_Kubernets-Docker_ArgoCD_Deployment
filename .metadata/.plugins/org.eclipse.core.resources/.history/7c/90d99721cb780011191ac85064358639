# =============================================================================
# PURPOSE
# =============================================================================
#
# Centralized observability configuration shared by all
# MSIMPL microservices.
#
# This configuration enables Spring Boot Actuator,
# Prometheus metrics and Kubernetes health probe
# endpoints without requiring any changes to
# application business logic.
#
# Observability settings are intentionally isolated
# from application.yml to separate infrastructure
# concerns from application-specific configuration.
#
# Responsibilities
# ----------------
# ✔ Enable Spring Boot Actuator
# ✔ Expose Health endpoint
# ✔ Expose Readiness endpoint
# ✔ Expose Liveness endpoint
# ✔ Expose Prometheus metrics
# ✔ Expose Application Information endpoint
# ✔ Configure common metric tags
# ✔ Support Kubernetes Health Probes
# ✔ Support centralized monitoring
# ✔ Environment-independent configuration
#
# =============================================================================
# OBSERVABILITY ARCHITECTURE
# =============================================================================
#
#                    Spring Boot Microservice
#                               │
#         ┌─────────────────────┼─────────────────────┐
#         │                     │                     │
#         ▼                     ▼                     ▼
# /actuator/health      /actuator/prometheus    Application Logs
#         │                     │                     │
#         │                     ▼                     ▼
#         │              Prometheus Server        Promtail
#         │                     │                     │
#         │                     ▼                     ▼
#         │             Grafana Dashboard          Loki
#         │                                           │
#         └───────────────────────────────────────────┘
#                             │
#                             ▼
#                     Grafana Dashboard
#
#
# Kubernetes Health Probes
# ------------------------
#
# Startup Probe
#        │
#        ▼
# /actuator/health
#
#
# Readiness Probe
#        │
#        ▼
# /actuator/health/readiness
#
#
# Liveness Probe
#        │
#        ▼
# /actuator/health/liveness
#
#
# Metrics Pipeline
# ----------------
#
# Spring Boot
#      │
#      ▼
# Spring Boot Actuator
#      │
#      ▼
# Prometheus
#      │
#      ▼
# Grafana
#
#
# Logs Pipeline
# -------------
#
# Application Logs
#        │
#        ▼
# Promtail
#        │
#        ▼
# Loki
#        │
#        ▼
# Grafana
#
#
# Prometheus collects METRICS.
# Promtail collects LOGS.
# Kubernetes consumes Health endpoints.
#
# These are independent observability pipelines.
#
# =============================================================================
# CONFIGURATION STRATEGY
# =============================================================================
#
# This configuration contains no environment-specific
# infrastructure values.
#
# The same configuration is used across:
#
# • Spring Tool Suite (STS)
# • Docker Compose
# • Kubernetes
# • AWS EKS
#
# Environment-specific deployment is handled through
# ConfigMaps, Secrets and deployment manifests rather
# than by application configuration.
#
# =============================================================================
# ENVIRONMENT SUPPORT
# =============================================================================
#
# Spring Tool Suite (STS)
# -----------------------
#
# Spring Boot exposes:
#
#     /actuator/health
#     /actuator/info
#     /actuator/prometheus
#
#
# Docker Compose
# --------------
#
# Prometheus scrapes metrics from Docker-hosted
# Spring Boot applications.
#
#
# Kubernetes
# ----------
#
# Spring Boot exposes Kubernetes health probe
# endpoints for Startup, Readiness and Liveness.
#
# Prometheus discovers application Pods through
# Kubernetes Service discovery and scrapes:
#
#     /actuator/prometheus
#
#
# AWS EKS
# -------
#
# Amazon Managed Prometheus or self-managed
# Prometheus may scrape application metrics.
#
# Kubernetes health probes continue to use
# Spring Boot Actuator endpoints.
#
# Grafana dashboards remain unchanged.
#
# =============================================================================
# MSIMPL DEPLOYMENT STANDARD
# =============================================================================
#
# ✔ STS Ready
# ✔ Docker Ready
# ✔ Kubernetes Ready
# ✔ AWS EKS Ready
# ✔ Spring Cloud Config Ready
# ✔ Kubernetes Startup Probe Ready
# ✔ Kubernetes Readiness Probe Ready
# ✔ Kubernetes Liveness Probe Ready
#
# This configuration is completely
# environment-independent.
#
# The same Spring Boot application,
# Docker image and observability configuration
# are used across all deployment environments.
#
# No application code changes are required.
# No Docker image rebuild is required.
#
# =============================================================================

management:

  # ===========================================================================
  # Actuator Endpoint Exposure
  # ===========================================================================
  #
  # Exposes selected Spring Boot Actuator endpoints.
  #
  # Available Endpoints
  #
  #   /actuator/health
  #   /actuator/health/liveness
  #   /actuator/health/readiness
  #   /actuator/info
  #   /actuator/prometheus
  #
  # These endpoints are consumed by:
  #
  # • Kubernetes Startup Probe
  # • Kubernetes Readiness Probe
  # • Kubernetes Liveness Probe
  # • Prometheus
  #
  # Production Recommendation
  #
  # Expose only the endpoints required by the
  # monitoring infrastructure.
  #
  endpoints:

    web:

      exposure:

        include:
          - health
          - info
          - prometheus

  # ===========================================================================
  # Health Endpoint Configuration
  # ===========================================================================
  #
  # Enables Spring Boot health endpoints required by
  # Kubernetes Deployment.
  #
  # Startup Probe
  # -------------
  #
  #     /actuator/health
  #
  # Readiness Probe
  # ----------------
  #
  #     /actuator/health/readiness
  #
  # Liveness Probe
  # --------------
  #
  #     /actuator/health/liveness
  #
  # These endpoints are consumed directly by
  # deployment.yaml.
  #
  # During development detailed health information
  # simplifies troubleshooting.
  #
  # Production Recommendation
  #
  #     show-details: when_authorized
  #
  endpoint:

    health:

      show-details: always

      probes:
        enabled: true

  # ===========================================================================
  # Health Groups
  # ===========================================================================
  #
  # Enables Kubernetes Readiness and Liveness probe
  # endpoints introduced in Spring Boot.
  #
  # These endpoints allow Kubernetes to determine:
  #
  # ✔ Application Startup
  # ✔ Traffic Readiness
  # ✔ Runtime Health
  #
  health:

    readinessState:
      enabled: true

    livenessState:
      enabled: true

  # ===========================================================================
  # Metrics Configuration
  # ===========================================================================
  #
  # Adds common tags to every exported metric.
  #
  # Example:
  #
  # application="ms-wallet"
  #
  # This allows Grafana dashboards to filter metrics
  # when monitoring multiple microservices.
  #
  metrics:

    tags:

      application: ${spring.application.name}

  # ===========================================================================
  # Prometheus Configuration
  # ===========================================================================
  #
  # Enables Prometheus metric export.
  #
  # Prometheus periodically scrapes:
  #
  #     /actuator/prometheus
  #
  # and stores application metrics.
  #
  prometheus:

    metrics:

      export:

        enabled: true
# =============================================================================
# VERIFICATION CHECKLIST
# =============================================================================
#
# Step 1
# ------
# Start the Spring Boot application.
#
#
# Step 2
# ------
# Verify Actuator endpoints.
#
# Example:
#
# http://localhost:8080/actuator
#
# Replace 8080 with the application's configured server port.
#
#
# Step 3
# ------
# Verify Prometheus endpoint.
#
# Example:
#
# http://localhost:8080/actuator/prometheus
#
# Expected metrics include:
#
# • jvm_memory_used_bytes
# • process_cpu_usage
# • system_cpu_usage
# • http_server_requests_seconds
#
#
# Step 4
# ------
# Verify Prometheus.
#
# Example:
#
# http://localhost:9090
#
# Navigate to:
#
# Status → Targets
#
# Verify the application target is UP.
#
#
# Step 5
# ------
# Verify Grafana.
#
# Example:
#
# http://localhost:3000
#
# Dashboards should display application metrics.
#
# =============================================================================
# TROUBLESHOOTING
# =============================================================================
#
# Problem
# -------
# Prometheus target is DOWN (404).
#
# Possible Causes
#
# ✔ application-observability.yml not imported
# ✔ micrometer-registry-prometheus dependency missing
# ✔ /actuator/prometheus not exposed
#
#
# Problem
# -------
# Only /actuator/health is visible.
#
# Possible Causes
#
# ✔ application-observability.yml not loaded
# ✔ Actuator endpoint exposure not configured
#
#
# Problem
# -------
# Metrics not visible in Grafana.
#
# Verify
#
# ✔ Prometheus target is UP
# ✔ Prometheus datasource configured
# ✔ Dashboard query is correct
#
#
# Problem
# -------
# No metrics appear in Prometheus.
#
# Verify
#
# ✔ Application is running
# ✔ Correct application port
# ✔ Prometheus scrape configuration
# ✔ Network connectivity
#
