# ==========================================================
# PostgreSQL Database Configuration
# ==========================================================
#
# Database Name
# Default database created during container initialization.
#
# Database User
# Default administrative user created by PostgreSQL.
#
# Database Password
# Password for the default PostgreSQL user.
#
# ==========================================================

POSTGRES_DB=wallet_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres


# ==========================================================
# PostgreSQL Storage Configuration
# ==========================================================
#
# PostgreSQL Data Directory
# Directory inside the container where PostgreSQL stores
# database files, transaction logs and metadata.
#
# ==========================================================

PGDATA=/var/lib/postgresql/data


