# ================================
# Global Prometheus Configuration
# ================================
# Author: Sanjeev
# Date: 19-June-2026
##################################
global:
  # scrape_interval defines how often Prometheus will scrape targets.
  # Here, metrics are collected every 5 seconds.
  scrape_interval: 5s

# ================================
# Scrape Configurations
# ================================
scrape_configs:

  # -------------------------------
  # Wallet Microservice
  # -------------------------------
  - job_name: 'ms-wallet'
    # Path where the Spring Boot actuator exposes Prometheus metrics
    metrics_path: '/actuator/prometheus'
    static_configs:
      # Target host and port where ms-wallet service runs
      - targets: ['host.docker.internal:8080']

  # -------------------------------
  # Notification Microservice
  # -------------------------------
  - job_name: 'ms-notification'
    metrics_path: '/actuator/prometheus'
    static_configs:
      # Target host and port where ms-notification service runs
      - targets: ['host.docker.internal:8081']

  # -------------------------------
  # Transaction Orchestrator Microservice
  # -------------------------------
  - job_name: 'ms-orchestrator'
    metrics_path: '/actuator/prometheus'
    static_configs:
      # Target host and port where ms-orchestrator service runs
      - targets: ['host.docker.internal:8082']
