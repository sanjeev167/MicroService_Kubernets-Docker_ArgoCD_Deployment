# =============================================================================
# PURPOSE
# =============================================================================
#
# Centralized database configuration for the Wallet Service.
#
# Responsibilities
# ----------------
# ✓ Database Connection Configuration
# ✓ JDBC Driver Configuration
# ✓ Connection Pool Configuration
# ✓ Environment Independent Configuration
#
# =============================================================================
# DESIGN PRINCIPLE
# =============================================================================
#
# This configuration is designed to work across multiple environments without
# changing application code or rebuilding the Docker image.
#
# The database connection is dynamically constructed using environment
# variables. Spring resolves each property using the following syntax:
#
#     ${VARIABLE_NAME:DefaultValue}
#
# Resolution Process
# ------------------
#
# 1. Check whether the environment variable exists.
# 2. If present, use its value.
# 3. Otherwise, use the specified default value.
#
# Example
#
#     ${DB_HOST:host.docker.internal}
#
# Means:
#
#     If DB_HOST exists
#            ↓
#     Use DB_HOST
#
#     Otherwise
#            ↓
#     Use host.docker.internal
#
# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
#
# Local Development (STS)
# -----------------------
#
# DB_HOST=localhost
#
# localhost correctly refers to the Windows machine where PostgreSQL is
# installed.
#
#
# Docker Container
# ----------------
#
# DB_HOST=host.docker.internal
#
# Inside a Docker container:
#
#     localhost
#
# refers to the container itself.
#
# Docker provides the special hostname:
#
#     host.docker.internal
#
# which resolves to the Windows host machine.
#
#
# Kubernetes (Docker Desktop)
# ---------------------------
#
# Pods also use:
#
#     host.docker.internal
#
# allowing applications running inside Kubernetes Pods to connect to the
# PostgreSQL server running on the Windows host.
#
#
# Kubernetes (Production)
# -----------------------
#
# DB_HOST=postgres-service
#
# where "postgres-service" is the Kubernetes Service name exposing the
# PostgreSQL Pod.
#
#
# AWS EKS
# -------
#
# DB_HOST=<Amazon RDS Endpoint>
#
# Example:
#
# wallet-db.xxxxxx.ap-south-1.rds.amazonaws.com
#
# Environment variables are injected using ConfigMaps and Secrets.
#
# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
#
# DB_HOST
#     Database Server Host
#
# DB_PORT
#     PostgreSQL Port
#
# DB_NAME
#     Database Name
#
# DB_USERNAME
#     Database User
#
# DB_PASSWORD
#     Database Password
#
# =============================================================================
# HIKARI CONNECTION POOL
# =============================================================================
#
# Connection Pool : HikariCP
#
# Maximum Pool Size : 10
#
# Minimum Idle Connections : 2
#
# Idle Timeout : 30000 ms
#
# =============================================================================
# MSIMPL INFRASTRUCTURE STANDARD (LOCKED)
# =============================================================================
#
# ✓ Environment Independent
# ✓ STS Ready
# ✓ Docker Ready
# ✓ Kubernetes Ready
# ✓ AWS EKS Ready
# ✓ Spring Cloud Config Ready
#
# The same application code and Docker image are used across all environments.
#
# Only environment variables change.
#
# =============================================================================

db:
  datasource:

    # =========================================================================
    # JDBC Connection URL
    #
    # The URL is dynamically constructed using environment variables.
    #
    # Local Kubernetes & Docker Desktop
    # ---------------------------------
    # Uses host.docker.internal by default to connect to PostgreSQL running on
    # the Windows host machine.
    #
    # STS
    # ---
    # Override DB_HOST=localhost in the IDE Run Configuration.
    #
    # AWS
    # ---
    # Override DB_HOST with the Amazon RDS endpoint through Kubernetes
    # ConfigMap or Secret.
    # =========================================================================
    url: jdbc:postgresql://${DB_HOST:host.docker.internal}:${DB_PORT:5432}/${DB_NAME:wallet_db}

    # Database Credentials
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD:postgres}

    # PostgreSQL JDBC Driver
    driver-class-name: org.postgresql.Driver

    # =========================================================================
    # Hikari Connection Pool Configuration
    # =========================================================================
    pool:
      max-size: 10
      min-idle: 2
      idle-timeout: 30000

