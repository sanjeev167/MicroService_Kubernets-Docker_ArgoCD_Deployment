#
# ==========================================================
# PURPOSE
# ==========================================================
#
# Centralized Kafka configuration for Wallet Service.
#
# Responsibilities
#
# ✔ Kafka Broker Configuration
# ✔ Producer Configuration
# ✔ Consumer Configuration
# ✔ Topic Configuration
# ✔ Consumer Group Configuration
#
# ==========================================================
# DESIGN PRINCIPLE
# ==========================================================
#
# Externalize all environment specific properties.
#
# Default Value
#
#     localhost:29092
#
# Docker
#
#     kafka:9092
#
# Kubernetes
#
#     kafka-service:9092
#
# AWS
#
#     MSK Endpoint
#
# No source code changes are required.
#
# ==========================================================
# 🔒 MSIMPL PHASE-1 STANDARD (LOCKED)
# ==========================================================
#
# ✔ Manual Kafka ACK
# ✔ Raw JSON Consumption
# ✔ Manual ObjectMapper Parsing
# ✔ Retry + DLQ Ready
#
# DO NOT CHANGE
#
#   - Deserializer
#   - ACK Strategy
#   - Offset Strategy
#
# without architectural review.
#
# ==========================================================

spring:

  kafka:

    # ======================================================
    # Kafka Broker
    # ======================================================

    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS:localhost:29092}

    # ======================================================
    # Producer Configuration
    # ======================================================

    producer:

      key-serializer: org.apache.kafka.common.serialization.StringSerializer

      value-serializer: org.springframework.kafka.support.serializer.JsonSerializer

      acks: all

      retries: 3

      properties:

        spring.json.add.type.headers: false

    # ======================================================
    # Consumer Configuration
    # ======================================================

    consumer:

      group-id: default-wallet-group

      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer

      value-deserializer: org.apache.kafka.common.serialization.StringDeserializer

      enable-auto-commit: false

      auto-offset-reset: earliest

      # ----------------------------------------------------
      # MSIMPL Standard
      # ----------------------------------------------------
      #
      # DO NOT USE JsonDeserializer
      #
      # Raw JSON is parsed manually using ObjectMapper.
      #
      # ----------------------------------------------------

# ==========================================================
# Wallet Topic Configuration
# ==========================================================

wallet:

  topic:

    request: wallet-request-topic

    response: wallet-response-topic

    compensation: wallet-compensation-topic

  consumer:

    group-id: wallet-consumer-group

# ==========================================================
# End Of File
