# PURPOSE
# ----------------------------------------------------------
# Centralized environment configuration for the Apache Kafka
# Docker container used in the local STS development
# environment.
#
# This file externalizes Kafka-specific configuration used by
# Docker Compose, allowing infrastructure settings to remain
# separate from container definitions. The same configuration
# approach can be reused in Kubernetes and cloud deployments
# through ConfigMaps and Secrets.
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# Primary Environment
# ✔ Spring Tool Suite (STS)
# ✔ Local Docker Compose
#
# Future Deployment Targets
# ----------------------------------------------------------
# ✔ Kubernetes
# ✔ AWS EKS
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Centralized infrastructure configuration
# ✔ Environment-specific configuration
# ✔ Reusable across deployment environments
# ✔ Single source of truth for Kafka configuration
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|--------------------------------------------
# 1.0.0   | 03-Jul-2026 | Sanjeev Kumar  | Initial Kafka environment configuration.
#
# ==========================================================


# ==========================================================
# Kafka KRaft Configuration
# ==========================================================
#
# Cluster ID
# Unique identifier for the Kafka KRaft cluster.
#
# Node ID
# Unique identifier for this Kafka broker.
#
# ==========================================================

KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_NODE_ID=1


# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# Internal Listener
# Used by Docker containers communicating over the shared
# Docker network.
#
# External Listener
# Used by applications running directly from Spring Tool
# Suite (STS) or other tools outside the Docker network.
#
# Controller Listener
# Used internally by Kafka KRaft for controller
# communication.
#
# ==========================================================

KAFKA_INTERNAL_HOST=kafka
KAFKA_INTERNAL_PORT=9092

KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=29092

KAFKA_CONTROLLER_PORT=9093


# ==========================================================
# Kafka Storage Configuration
# ==========================================================
#
# Directory used by Kafka KRaft to store cluster metadata,
# broker metadata, and message log segments.
#
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs


# ==========================================================
# Kafka Broker Configuration
# ==========================================================
#
# Offset Topic Replication Factor
# Single-node development environment uses a replication
# factor of one.
#
# Auto Topic Creation
# Automatically creates topics when first accessed.
# Enabled only for local development.
# Disable in production environments.
#
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true


# ==========================================================
# End Of File
