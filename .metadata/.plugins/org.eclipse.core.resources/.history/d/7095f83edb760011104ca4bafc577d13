# ==========================================================
# OBSERVABILITY CONFIGURATION
# File      : application-observability.yml
# Service   : All MSIMPL Microservices
# Author    : Sanjeev Kumar
# Date      : 01-July-2026
#
# ==========================================================
# PURPOSE
# ----------------------------------------------------------
# This file centralizes all observability-related
# configuration for MSIMPL microservices.
#
# It enables Spring Boot Actuator and Prometheus metrics,
# allowing applications to be monitored without modifying
# business logic.
#
# The configuration is intentionally isolated from
# application.yml to keep infrastructure concerns separate
# from application-specific configuration.
#
# ==========================================================
# ARCHITECTURE
# ----------------------------------------------------------
#
#            Spring Boot Microservice
#                     │
#                     │
#        /actuator/prometheus
#                     │
#                     ▼
#               Prometheus Server
#                     │
#                     ▼
#                 Grafana Dashboard
#
# Logs follow a separate pipeline:
#
#     Application Logs
#             │
#             ▼
#        Promtail
#             │
#             ▼
#            Loki
#             │
#             ▼
#          Grafana
#
# NOTE:
# Prometheus collects METRICS.
# Promtail collects LOGS.
# These are two independent observability pipelines.
#
# ==========================================================
# RESPONSIBILITIES
# ----------------------------------------------------------
# ✔ Enable Spring Boot Actuator
# ✔ Expose Prometheus metrics endpoint
# ✔ Expose Health endpoint
# ✔ Expose Application information endpoint
# ✔ Add common metric tags
# ✔ Support Grafana dashboards
# ✔ Support Docker deployment
# ✔ Support Kubernetes deployment
# ✔ Support AWS deployment
#
# ==========================================================
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ No impact on business logic
# ✔ Read-only monitoring endpoints
# ✔ Infrastructure configuration separated from
#   application configuration
# ✔ Common configuration shared across all services
# ✔ Kubernetes Ready
# ✔ Docker Ready
# ==========================================================

management:

  # ========================================================
  # ACTUATOR ENDPOINT EXPOSURE
  # ========================================================
  #
  # Exposes selected Actuator endpoints over HTTP.
  #
  # Exposed Endpoints:
  #
  #   /actuator/health
  #   /actuator/info
  #   /actuator/prometheus
  #
  # Security Note:
  # In production expose only the endpoints required
  # by monitoring infrastructure.
  #
  endpoints:
    web:
      exposure:
        include:
          - health
          - info
          - prometheus

  # ========================================================
  # HEALTH ENDPOINT CONFIGURATION
  # ========================================================
  #
  # Controls the behaviour of:
  #
  #   /actuator/health
  #
  # During development detailed health information
  # helps diagnose configuration problems.
  #
  # Production Recommendation:
  # show-details: when_authorized
  #
  endpoint:
    health:
      show-details: always

  # ========================================================
  # METRICS CONFIGURATION
  # ========================================================
  #
  # Adds common tags to every metric exported by
  # Spring Boot.
  #
  # Example:
  #
  # application="ms-wallet"
  #
  # This makes it easier to filter dashboards in
  # Grafana when multiple services are monitored.
  #
  metrics:

    tags:
      application: ${spring.application.name}

  # ========================================================
  # PROMETHEUS CONFIGURATION
  # ========================================================
  #
  # Enables Prometheus metric export.
  #
  # Prometheus periodically calls:
  #
  #   /actuator/prometheus
  #
  # and stores the collected metrics.
  #
  # Without this configuration:
  #
  #   http://localhost:8080/actuator/prometheus
  #
  # returns HTTP 404.
  #
  prometheus:
    metrics:
      export:
        enabled: true


# ==========================================================
# VERIFICATION CHECKLIST
# ==========================================================
#
# STEP 1
# -------
# Start the Spring Boot application.
#
# STEP 2
# -------
# Verify Actuator:
#
# http://localhost:8080/actuator
#
# Expected:
#
#   health
#   info
#   prometheus
#
#
# STEP 3
# -------
# Verify Prometheus endpoint:
#
# http://localhost:8080/actuator/prometheus
#
# Expected:
#
# jvm_memory_used_bytes
# process_cpu_usage
# system_cpu_usage
# http_server_requests_seconds
#
#
# STEP 4
# -------
# Verify Prometheus Server:
#
# http://localhost:9090
#
# Status
#   → Targets
#
# Expected:
#
# ms-wallet      UP
#
#
# STEP 5
# -------
# Verify Grafana:
#
# http://localhost:3000
#
# Dashboards should display application metrics.
#
# ==========================================================
# TROUBLESHOOTING
# ==========================================================
#
# Problem:
# Prometheus Target = DOWN (404)
#
# Possible Causes:
#
# ✔ application-observability.yml not imported
# ✔ micrometer-registry-prometheus dependency missing
# ✔ /actuator/prometheus not exposed
#
#
# Problem:
# Only /actuator/health is visible
#
# Cause:
# application-observability.yml not loaded or
# Actuator endpoint exposure configuration missing.
#
#
# Problem:
# Metrics not visible in Grafana
#
# Check:
#
# ✔ Prometheus Target is UP
# ✔ Datasource configured correctly
# ✔ Dashboard query is correct
#
# ==========================================================
# END OF FILE
# ==========================================================