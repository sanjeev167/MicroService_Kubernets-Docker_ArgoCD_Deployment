# ==========================================================
# Observability Configuration
# File : application-observability.yml
#
# Purpose
# -------
# Centralized observability configuration for MSIMPL.
#
# Includes:
# ✔ Spring Boot Actuator
# ✔ Prometheus Metrics
# ✔ Health Endpoints
# ✔ Application Metrics Tags
#
# ==========================================================

management:

  endpoints:
    web:
      exposure:
        include:
          - health
          - info
          - prometheus

  endpoint:
    health:
      show-details: always # ⚠ Restrict in production

  metrics:
    tags:
      application: ${spring.application.name}

  prometheus:
    metrics:
      export:
        enabled: true
        
        
        
# ==========================================================
# 📌 VERIFICATION STEPS
# ==========================================================
#
# 1. Start Service
#
# 2. Access:
#    http://localhost:8080/actuator/prometheus
#
# 3. Expected Metrics:
#    - jvm_memory_used_bytes
#    - http_server_requests_seconds
#    - process_cpu_usage
#
# ==========================================================