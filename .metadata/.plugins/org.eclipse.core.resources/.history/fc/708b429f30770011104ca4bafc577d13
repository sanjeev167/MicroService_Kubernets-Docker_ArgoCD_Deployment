# =============================================================================
# WALLET SERVICE
# =============================================================================

  ms-wallet:

    image: ms-wallet:1.0.0

    container_name: ms-wallet

    hostname: ms-wallet

    ports:
      - "8080:8080"

    env_file:
      - ./env/wallet.env

    restart: unless-stopped

    networks:
      - infra_msimpl-network



# =============================================================================
# NOTIFICATION SERVICE
# =============================================================================

  ms-notification:

    image: ms-notification:1.0.0

    container_name: ms-notification

    hostname: ms-notification

    ports:
      - "8081:8081"

    env_file:
      - ./env/notification.env

    restart: unless-stopped

    networks:
      - infra_msimpl-network



# =============================================================================
# TRANSACTION ORCHESTRATOR
# =============================================================================

  ms-transaction-orchestrator:

    image: ms-transaction-orchestrator:1.0.0

    container_name: ms-transaction-orchestrator

    hostname: ms-transaction-orchestrator

    ports:
      - "8082:8082"

    env_file:
      - ./env/transaction-orchestrator.env

    restart: unless-stopped

    depends_on:
      - ms-wallet
      - ms-notification

    networks:
      - infra_msimpl-network



# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

networks:

  infra_msimpl-network:

    external: true