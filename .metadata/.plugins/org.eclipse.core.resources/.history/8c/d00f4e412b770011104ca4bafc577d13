# PURPOSE
# ----------------------------------------------------------
# Centralized runtime configuration for Kafka UI used by the
# Docker infrastructure.
#
# Docker Compose injects these variables directly into the
# Kafka UI container through:
#
#     env_file:
#       - ./env/kafka-ui.env
#
# ==========================================================


# ==========================================================
# Kafka Cluster Configuration
# ==========================================================
#
# Kafka UI connects to the Kafka broker using the Docker
# bridge network.
#
# All Docker containers communicate using their container
# names.
#
# Example:
#
#     kafka:9092
#
# ==========================================================

KAFKA_CLUSTER_NAME=MSIMPL

KAFKA_BOOTSTRAP_SERVER=kafka:9092


# ==========================================================
# Kafka UI Configuration
# ==========================================================
#
# Enables runtime management of Kafka clusters without
# rebuilding or restarting the container.
#
# ==========================================================

KAFKA_UI_DYNAMIC_CONFIG_ENABLED=true


