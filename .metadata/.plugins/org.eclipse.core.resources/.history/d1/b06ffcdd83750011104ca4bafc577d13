# ==========================================================
# PROMTAIL CONFIGURATION (MSIMPL LOG COLLECTION AGENT)
# ==========================================================
# Author: Sanjeev
# Date: 20-June-2026
# Version: v3 (Production Ready)
#
# ==========================================================
# 🎯 PURPOSE
# ----------------------------------------------------------
# * Collect logs from centralized logs directory (outside services)
# * Push logs to Loki for storage and querying
# * Enable service-level observability in Grafana
#
# ==========================================================
# 🔄 LOG FLOW ARCHITECTURE
# ----------------------------------------------------------
#   Microservices (Spring Boot)
#            ↓
#   logs/*.log  (Host filesystem)
#            ↓
#   Promtail (Log shipper)
#            ↓
#   Loki (Storage + Indexing)
#            ↓
#   Grafana (Visualization)
#
# ==========================================================
# 🧠 DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Logs are OUTSIDE services (no container coupling)
# ✔ No code dependency for logging pipeline
# ✔ Lightweight shipping (no heavy agents)
# ✔ Service detection via filename (convention-based)
# ✔ Scalable to N microservices without config change
#
# ==========================================================
# ⚠️ CRITICAL CONVENTIONS
# ----------------------------------------------------------
# 1. Docker Volume Mapping:
#    Host logs directory MUST be mounted to:
#        /var/log/app (inside container)
#
#    Example (docker-compose):
#        ../logs:/var/log/app
#
# ----------------------------------------------------------
# 2. Log File Naming Convention:
#
#    ms-wallet.log
#    ms-notification.log
#    ms-transaction-orchestrator.log
#
#    👉 This is REQUIRED for auto service labeling
#
# ----------------------------------------------------------
# 3. Log Format:
#    Currently plain text (Spring Boot default)
#    Future upgrade → JSON structured logs
#
# ==========================================================


# ==========================================================
# 🚀 SERVER CONFIGURATION
# ==========================================================
# Exposes Promtail HTTP endpoint (for health/debugging)
server:
  http_listen_port: 9080


# ==========================================================
# 📍 POSITION TRACKING (OFFSET MANAGEMENT)
# ==========================================================
# Tracks how much of each file has been read
# Prevents duplicate ingestion on restart
#
# ⚠️ IMPORTANT:
# If logs are not appearing, delete this file:
#   docker exec -it promtail rm /tmp/positions.yaml
#
positions:
  filename: /tmp/positions.yaml


# ==========================================================
# 📡 LOKI CLIENT CONFIGURATION
# ==========================================================
# Push logs to Loki using internal Docker DNS
#
# ⚠️ REQUIREMENT:
# Promtail and Loki must be in SAME Docker network
#
clients:
  - url: http://loki:3100/loki/api/v1/push


# ==========================================================
# 📥 SCRAPE CONFIGURATION
# ==========================================================
scrape_configs:

  # ========================================================
  # 🟢 SPRING BOOT MICROSERVICE LOGS
  # ========================================================
  - job_name: spring-boot-logs

    # ------------------------------------------------------
    # Static file-based scraping
    # ------------------------------------------------------
    static_configs:
      - targets:
          - localhost   # Required dummy value

        labels:
          # ----------------------------------------------
          # 🔖 CORE LABELS (used in Grafana queries)
          # ----------------------------------------------
          job: msimpl
          env: local
          type: application

          # ----------------------------------------------
          # 📁 FILE PATH INSIDE CONTAINER
          # MUST match Docker volume mount
          # ----------------------------------------------
          __path__: /var/log/app/*.log


    # ======================================================
    # 🔧 PIPELINE STAGES (LOG ENRICHMENT)
    # ======================================================
    #
    # These stages transform raw logs into labeled logs
    #
    pipeline_stages:

      # ----------------------------------------------------
      # 1️⃣ Extract service name from filename
      #
      # Example:
      #   /var/log/app/ms-wallet.log → service=ms-wallet
      # ----------------------------------------------------
      - regex:
          source: filename
          expression: '.*/(?P<service>[^/]+)\.log'

      # ----------------------------------------------------
      # 2️⃣ Attach extracted value as label
      # ----------------------------------------------------
      - labels:
          service:

      # ----------------------------------------------------
      # (Future Enhancement)
      # ----------------------------------------------------
      # - json:
      #     expressions:
      #       level: level
      #       traceId: traceId
      #       txnId: txnId
      #
      # - labels:
      #     level:
      #     traceId:
      #
      # ----------------------------------------------------


# ==========================================================
# 📊 GRAFANA QUERY EXAMPLES (LOGQL)
# ==========================================================
#
# 🔹 All logs
#   {job="msimpl"}
#
# 🔹 Service-specific logs
#   {service="ms-wallet"}
#
# 🔹 Error logs
#   {job="msimpl"} |= "ERROR"
#
# 🔹 Transaction tracing
#   {job="msimpl"} |= "txnId=123"
#
# 🔹 Service + Error
#   {service="ms-wallet"} |= "FAILED"
#
# 🔹 Multi-filter
#   {service="ms-wallet"} |= "ERROR" |= "timeout"
#
# ==========================================================


# ==========================================================
# 🧪 DEBUG / TROUBLESHOOTING GUIDE
# ==========================================================
#
# ✔ Step 1: Verify logs exist (host)
#   dir ../logs
#
# ✔ Step 2: Verify logs inside container
#   docker exec -it promtail sh
#   ls /var/log/app
#
# ✔ Step 3: Check Promtail logs
#   docker logs promtail
#
#   Look for:
#     "tail routine: started"
#
# ✔ Step 4: Check Loki readiness
#   curl http://localhost:3100/ready
#
# ✔ Step 5: Check labels in Loki
#   curl http://localhost:3100/loki/api/v1/labels
#
# ✔ Step 6: Query logs in Grafana
#   {job="msimpl"}
#
# ==========================================================


# ==========================================================
# ⚠️ COMMON PITFALLS
# ==========================================================
#
# ❌ Logs not appearing
#    → Promtail reading from end (positions file issue)
#
# ❌ No service label
#    → Regex not matching filename
#
# ❌ "no such host loki"
#    → Network mismatch
#
# ❌ Logs exist but not updating
#    → No new logs generated
#
# ❌ Empty Grafana view
#    → Wrong query or time range
#
# ==========================================================


