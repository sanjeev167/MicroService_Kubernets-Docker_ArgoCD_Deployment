# PURPOSE
# ----------------------------------------------------------
# Provides the core infrastructure required for local
# development using Spring Tool Suite (STS).
#
# Spring Boot microservices run directly from STS while
# infrastructure services execute inside Docker.
#
# INCLUDED SERVICES
# ----------------------------------------------------------
# ✔ PostgreSQL
# ✔ Apache Kafka (KRaft Mode)
# ✔ Kafka UI
#
# EXCLUDED SERVICES
# ----------------------------------------------------------
# ✘ Spring Boot Microservices
# ✘ Redis
# ✘ Prometheus
# ✘ Grafana
# ✘ Loki
# ✘ Promtail
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# ✔ Local Development (STS)
#
# Future Support
# ----------------------------------------------------------
# ✔ Docker Compose
# ✔ Kubernetes
# ✔ AWS EKS
#
# NETWORK STRATEGY
# ----------------------------------------------------------
# All infrastructure services communicate using the shared
# Docker network:
#
#     infra_msimpl-network
#
# Spring Boot applications running from STS connect using
# published Docker ports.
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Environment-specific infrastructure
# ✔ Environment-independent application
# ✔ Externalized configuration using .env files
# ✔ Same application code across all environments
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|--------------------------------------------
# 1.0.0   | 03-Jul-2026 | Sanjeev Kumar  | Initial local infrastructure stack.
#
# ==========================================================

version: "3.8"

services:

  # ==========================================================
  # 🐘 POSTGRESQL DATABASE
  # ==========================================================
  #
  # Primary relational database for MSIMPL microservices.
  #
  # Configuration
  # ----------------------------------------------------------
  # Environment variables are loaded from:
  #
  #     ./env/postgres.env
  #
  # ==========================================================
  postgres:

    image: postgres:17

    container_name: postgres

    ports:
      - "5432:5432"

    env_file:
      - ./env/postgres.env

    volumes:
      - postgres-data:/var/lib/postgresql/data

    networks:
      - infra_msimpl-network

    restart: unless-stopped


  # ==========================================================
  # 🟡 APACHE KAFKA (KRaft Mode)
  # ==========================================================
  #
  # Enterprise event streaming platform used by MSIMPL
  # microservices.
  #
  # Configuration
  # ----------------------------------------------------------
  # Static values are loaded from:
  #
  #     ./env/kafka.env
  #
  # Listener expressions are assembled below using those
  # environment variables.
  #
  # ==========================================================
  kafka:

    image: confluentinc/cp-kafka:7.5.0

    container_name: kafka

    ports:
      - "9092:9092"
      - "29092:29092"

    env_file:
      - ./env/kafka.env

    environment:

      # ------------------------------------------------------
      # KRaft Configuration
      # ------------------------------------------------------
      CLUSTER_ID: ${KAFKA_CLUSTER_ID}
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_NODE_ID: ${KAFKA_NODE_ID}
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:${KAFKA_CONTROLLER_PORT}

      # ------------------------------------------------------
      # Listener Configuration
      # ------------------------------------------------------
      KAFKA_LISTENERS: >
        PLAINTEXT://0.0.0.0:${KAFKA_INTERNAL_PORT},
        PLAINTEXT_HOST://0.0.0.0:${KAFKA_EXTERNAL_PORT},
        CONTROLLER://0.0.0.0:${KAFKA_CONTROLLER_PORT}

      KAFKA_ADVERTISED_LISTENERS: >
        PLAINTEXT://${KAFKA_INTERNAL_HOST}:${KAFKA_INTERNAL_PORT},
        PLAINTEXT_HOST://${KAFKA_EXTERNAL_HOST}:${KAFKA_EXTERNAL_PORT}

      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: >
        PLAINTEXT:PLAINTEXT,
        PLAINTEXT_HOST:PLAINTEXT,
        CONTROLLER:PLAINTEXT

      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT

      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER

      # ------------------------------------------------------
      # Storage Configuration
      # ------------------------------------------------------
      KAFKA_LOG_DIRS: ${KAFKA_LOG_DIRS}

      # ------------------------------------------------------
      # Broker Configuration
      # ------------------------------------------------------
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: ${KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR}
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: ${KAFKA_AUTO_CREATE_TOPICS_ENABLE}

    networks:
      - infra_msimpl-network

    restart: unless-stopped


  # ==========================================================
  # 🟠 KAFKA UI
  # ==========================================================
  #
  # Web-based user interface for monitoring Kafka clusters.
  #
  # ==========================================================
  kafka-ui:

    image: provectuslabs/kafka-ui

    container_name: kafka-ui

    ports:
      - "8085:8080"

    environment:
      KAFKA_CLUSTERS_0_NAME: Local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092

    depends_on:
      - kafka

    networks:
      - infra_msimpl-network

    restart: unless-stopped


# ==========================================================
# NETWORK CONFIGURATION
# ==========================================================
networks:

  infra_msimpl-network:
    external: true


# ==========================================================
# PERSISTENT VOLUMES
# ==========================================================
volumes:

  postgres-data: