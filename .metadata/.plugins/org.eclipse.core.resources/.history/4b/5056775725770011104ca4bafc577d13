# =============================================================================
# File Name   : docker-compose.yml
# Module      : Docker Infrastructure
# Environment : Docker
# Project     : Microservices Platform (MSIMPL)
# Author      : Sanjeev Kumar
# Created On  : 04-Jul-2026
# =============================================================================
#
# Description
# -----------
# This Docker Compose file provisions the infrastructure components required
# by the MSIMPL microservices in the Docker environment.
#
# Infrastructure Components
# -------------------------
# 1. Apache Kafka (KRaft Mode)
# 2. Kafka UI
#
# Notes
# -----
# 1. PostgreSQL is installed on the Windows host and is NOT deployed as a
#    Docker container.
#
# 2. This compose file defines the Docker infrastructure topology including:
#
#       - Docker Images
#       - Container Names
#       - Host Names
#       - Port Mappings
#       - Docker Networks
#       - Docker Volumes
#
# 3. Runtime configuration for each infrastructure component is externalized
#    into dedicated environment files located under:
#
#       infrastructure/env/
#
# 4. This infrastructure must be started before deploying any
#    MSIMPL microservice containers.
#
# =============================================================================

services:

  # ===========================================================================
  # Apache Kafka
  # ===========================================================================
  #
  # Purpose
  # -------
  # Provides the distributed event streaming platform used by all MSIMPL
  # microservices.
  #
  # Mode
  # ----
  # KRaft (ZooKeeper-less)
  #
  # Runtime Configuration
  # ---------------------
  # Runtime properties are loaded from:
  #
  #     env/kafka.env
  #
  # ===========================================================================

  kafka:

    image: confluentinc/cp-kafka:7.5.0

    container_name: kafka

    hostname: kafka

    restart: unless-stopped

    env_file:
      - ./env/kafka.env

    ports:
      - "29092:9092"

    environment:

      KAFKA_NODE_ID: ${KAFKA_NODE_ID}

      KAFKA_PROCESS_ROLES: ${KAFKA_PROCESS_ROLES}

      KAFKA_CLUSTER_ID: ${KAFKA_CLUSTER_ID}

      KAFKA_CONTROLLER_QUORUM_VOTERS: ${KAFKA_CONTROLLER_QUORUM}

      KAFKA_LISTENERS: ${KAFKA_LISTENERS}

      KAFKA_ADVERTISED_LISTENERS: ${KAFKA_ADVERTISED_LISTENERS}

      KAFKA_CONTROLLER_LISTENER_NAMES: ${KAFKA_CONTROLLER_LISTENER_NAMES}

      KAFKA_INTER_BROKER_LISTENER_NAME: ${KAFKA_INTER_BROKER_LISTENER_NAME}

      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: ${KAFKA_LISTENER_SECURITY_PROTOCOL_MAP}

      KAFKA_LOG_DIRS: ${KAFKA_LOG_DIRS}

      KAFKA_HEAP_OPTS: ${KAFKA_HEAP_OPTS}

      KAFKA_LOG4J_ROOT_LOGLEVEL: ${KAFKA_LOG_LEVEL}

    volumes:
      - kafka-data:/var/lib/kafka/data

    networks:
      - msimpl-network



  # ===========================================================================
  # Kafka UI
  # ===========================================================================
  #
  # Purpose
  # -------
  # Web-based administration console used to monitor Kafka clusters,
  # topics, partitions, consumer groups and published messages.
  #
  # Runtime Configuration
  # ---------------------
  # Runtime properties are loaded from:
  #
  #     env/kafka-ui.env
  #
  # ===========================================================================

  kafka-ui:

    image: provectuslabs/kafka-ui:latest

    container_name: kafka-ui

    hostname: kafka-ui

    restart: unless-stopped

    env_file:
      - ./env/kafka-ui.env

    depends_on:
      - kafka

    ports:
      - "8080:8080"

    environment:

      KAFKA_CLUSTERS_0_NAME: ${KAFKA_CLUSTER_NAME}

      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: ${KAFKA_BOOTSTRAP_SERVER}

      DYNAMIC_CONFIG_ENABLED: ${KAFKA_UI_DYNAMIC_CONFIG_ENABLED}

    networks:
      - msimpl-network



# =============================================================================
# Docker Persistent Volumes
# =============================================================================

volumes:

  kafka-data:

    name: kafka-data



# =============================================================================
# Docker Networks
# =============================================================================

networks:

  msimpl-network:

    name: msimpl-network

    driver: bridge