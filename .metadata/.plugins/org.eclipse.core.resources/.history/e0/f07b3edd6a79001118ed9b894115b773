# ==========================================================
# Kubernetes ConfigMap
# File      : config-map-kafka.yaml
# Project   : MSIMPL - Microservices Platform
# Author    : Sanjeev Kumar
#
# Description
# -----------
# Stores common, non-sensitive Kafka configuration shared
# across all MSIMPL microservices.
#
# Purpose
# -------
# - Kafka bootstrap server
# - Consumer behavior
# - Producer behavior
#
# Notes
# -----
# - Do NOT store Kafka username/password here.
# - Authentication credentials must be stored in
#   Kubernetes Secrets.
# - Service-specific Kafka properties should remain in the
#   respective Spring Boot application-kafka.yml files.
#
# ==========================================================

apiVersion: v1
kind: ConfigMap

metadata:
  name: msimpl-kafka-config
  namespace: msimpl

  labels:
    app.kubernetes.io/name: msimpl
    app.kubernetes.io/component: kafka-config
    app.kubernetes.io/part-of: microservices-platform

data:

  # --------------------------------------------------------
  # Kafka Connection
  # --------------------------------------------------------
  KAFKA_HOST: "kafka"

  KAFKA_PORT: "9092"

  # --------------------------------------------------------
  # Consumer Configuration
  # --------------------------------------------------------
  KAFKA_AUTO_OFFSET_RESET: "earliest"

  KAFKA_ENABLE_AUTO_COMMIT: "false"

  # --------------------------------------------------------
  # Producer Configuration
  # --------------------------------------------------------
  KAFKA_ACKS: "all"

  KAFKA_RETRIES: "3"