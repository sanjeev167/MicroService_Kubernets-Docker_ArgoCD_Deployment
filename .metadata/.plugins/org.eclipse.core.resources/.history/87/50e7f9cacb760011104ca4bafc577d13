# PURPOSE
# ----------------------------------------------------------
# Centralized environment configuration for the Apache Kafka
# Docker container.
#
# This file externalizes Kafka-specific configuration used by
# Docker Compose, allowing environment-specific values to be
# maintained separately from infrastructure definitions.
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# ✔ Local Development (STS)
#
# Future Support
# ----------------------------------------------------------
# ✔ Docker Compose
# ✔ Kubernetes
# ✔ AWS EKS
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ Environment-specific configuration
# ✔ No hardcoded infrastructure values
# ✔ Reusable across deployment environments
# ✔ Single source of truth for Kafka configuration
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|--------------------------------------------
# 1.0.0   | 03-Jul-2026 | Sanjeev Kumar  | Initial Kafka environment configuration.
#
# ==========================================================


# ==========================================================
# Kafka KRaft Configuration
# ==========================================================
#
# Unique Cluster Identifier
# Used by Kafka KRaft mode to identify the Kafka cluster.
#
# Node ID
# Unique identifier of the Kafka broker within the cluster.
#
# ==========================================================

KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_NODE_ID=1


# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# Internal Host
# Used by Docker containers communicating over the shared
# Docker network.
#
# External Host
# Used by applications running outside Docker, such as STS.
#
# Controller Port
# Internal KRaft controller communication.
#
# ==========================================================

KAFKA_INTERNAL_HOST=kafka
KAFKA_INTERNAL_PORT=9092

KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=29092

KAFKA_CONTROLLER_PORT=9093


# ==========================================================
# Kafka Storage Configuration
# ==========================================================
#
# Directory used by Kafka to store metadata and log segments.
#
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs


# ==========================================================
# Kafka Broker Configuration
# ==========================================================
#
# Offset Topic Replication Factor
# Single-node development environment uses replication
# factor of one.
#
# Auto Topic Creation
# Automatically creates topics when first accessed.
# Suitable for development environments.
#
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true


