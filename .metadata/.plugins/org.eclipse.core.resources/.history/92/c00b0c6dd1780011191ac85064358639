# ============================================================================
# MSIMPL - Kubernetes Service Configuration
#
# File        : ms-wallet-service.yaml
# Service     : ms-wallet
# Environment : Kubernetes
# Author      : Sanjeev Kumar
#
# Description
# -----------
# This file creates a Kubernetes Service for the ms-wallet microservice.
#
# A Service provides a stable network endpoint for one or more Pods.
# Pods are temporary resources whose names and IP addresses change whenever
# they are recreated (during rolling updates, failures, scaling, etc.).
#
# Instead of communicating directly with Pod IP addresses, other
# microservices communicate with this Service.
#
# Example:
#     http://ms-wallet:8080
#
# Kubernetes automatically forwards the request to one of the healthy
# Wallet Pods.
#
# This Service uses the ClusterIP type because ms-wallet is an internal
# microservice. It is intended to be consumed only by other services inside
# the Kubernetes cluster and is not exposed directly to external clients.
# ============================================================================

apiVersion: v1
kind: Service
metadata:
  # --------------------------------------------------------------------------
  # Name of the Service.
  # --------------------------------------------------------------------------
  name: ms-wallet

  # --------------------------------------------------------------------------
  # Namespace where this Service will be created.
  # --------------------------------------------------------------------------
  namespace: msimpl

spec:
  # --------------------------------------------------------------------------
  # Service Type
  # --------------------------------------------------------------------------
  type: ClusterIP

  # --------------------------------------------------------------------------
  # Service Selector
  # --------------------------------------------------------------------------
  selector:
    app: ms-wallet

  # --------------------------------------------------------------------------
  # Port Configuration
  # --------------------------------------------------------------------------
  ports:
    - protocol: TCP
      port: 8080
      targetPort: 8080
