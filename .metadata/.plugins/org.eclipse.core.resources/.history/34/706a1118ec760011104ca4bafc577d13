#
# PURPOSE
# ----------------------------------------------------------
# Provides the Docker-based infrastructure required for
# running MSIMPL microservices directly from Spring Tool
# Suite (STS).
#
# Spring Boot microservices execute from STS while shared
# infrastructure services execute inside Docker containers.
# This enables application development without installing
# infrastructure components directly on the host machine.
#
#
# INCLUDED SERVICES
# ----------------------------------------------------------
# ✔ Apache Kafka (KRaft Mode)
# ✔ Kafka UI (Cluster Monitoring)
#
#
# EXCLUDED SERVICES
# ----------------------------------------------------------
# ✘ PostgreSQL
#     PostgreSQL executes directly on the Windows host and
#     is accessed by Spring Boot applications running from STS.
#
# ✘ Spring Boot Microservices
#     Executed directly from Spring Tool Suite (STS).
#
# ✘ Prometheus
# ✘ Grafana
# ✘ Loki
# ✘ Promtail
#     Managed separately through the STS Observability
#     Docker Compose stack.
#
#
# DEPLOYMENT TARGET
# ----------------------------------------------------------
# Primary Environment
# ✔ Spring Tool Suite (STS)
#
# Infrastructure Runtime
# ✔ Docker Compose
#
# Future Deployment Targets
# ----------------------------------------------------------
# ✔ Kubernetes
# ✔ AWS EKS
#
#
# ARCHITECTURE
# ----------------------------------------------------------
#
#             Spring Boot Services
#                (Running in STS)
#                     │
#         ┌───────────┴───────────┐
#         │                       │
#         ▼                       ▼
# PostgreSQL              Apache Kafka
# (Windows Host)       (Docker Container)
#
#
# NETWORK STRATEGY
# ----------------------------------------------------------
# All Docker-based infrastructure services communicate
# through the shared Docker bridge network:
#
#     infra_msimpl-network
#
# Spring Boot applications running from STS connect to
# Docker containers through the published Docker ports.
#
#
# CONFIGURATION STRATEGY
# ----------------------------------------------------------
# Container-specific configuration is externalized into
# dedicated environment files. This keeps infrastructure
# configuration separate from container definitions and
# simplifies future migration to Kubernetes ConfigMaps
# and Secrets.
#
#     env/
#       ├── kafka.env
#       └── postgres.env
#
#
# DESIGN PRINCIPLES
# ----------------------------------------------------------
# ✔ STS-specific infrastructure stack
# ✔ Externalized container configuration
# ✔ Environment-independent application code
# ✔ Reusable deployment strategy
# ✔ Same application artifact across environments
# ✔ No application rebuild between environments
#
#
# VERSION HISTORY
# ----------------------------------------------------------
# Version | Date        | Author         | Description
# --------|-------------|----------------|-----------------------------------------
# 1.0.0   | 03-Jul-2026 | Sanjeev Kumar  | Initial STS infrastructure stack.
#
# ==========================================================

version: "3.8"

services:

  # ==========================================================
  # APACHE KAFKA (KRaft Mode)
  # ==========================================================
  #
  # Provides the messaging infrastructure for Spring Boot
  # microservices running directly from STS.
  #
  kafka:

    image: confluentinc/cp-kafka:7.5.0

    container_name: kafka

    ports:
      - "9092:9092"
      - "29092:29092"

    env_file:
      - ./env/kafka.env

    environment:

      # ------------------------------------------------------
      # KRaft Configuration
      # ------------------------------------------------------
      CLUSTER_ID: ${KAFKA_CLUSTER_ID}
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_NODE_ID: ${KAFKA_NODE_ID}
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:${KAFKA_CONTROLLER_PORT}

      # ------------------------------------------------------
      # Listener Configuration
      # ------------------------------------------------------
      #
      # PLAINTEXT
      # Communication between Docker containers.
      #
      # PLAINTEXT_HOST
      # Communication from Spring Boot applications
      # running directly from STS.
      #
      KAFKA_LISTENERS: >
        PLAINTEXT://0.0.0.0:${KAFKA_INTERNAL_PORT},
        PLAINTEXT_HOST://0.0.0.0:${KAFKA_EXTERNAL_PORT},
        CONTROLLER://0.0.0.0:${KAFKA_CONTROLLER_PORT}

      KAFKA_ADVERTISED_LISTENERS: >
        PLAINTEXT://${KAFKA_INTERNAL_HOST}:${KAFKA_INTERNAL_PORT},
        PLAINTEXT_HOST://${KAFKA_EXTERNAL_HOST}:${KAFKA_EXTERNAL_PORT}

      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: >
        PLAINTEXT:PLAINTEXT,
        PLAINTEXT_HOST:PLAINTEXT,
        CONTROLLER:PLAINTEXT

      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT

      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER

      # ------------------------------------------------------
      # Storage Configuration
      # ------------------------------------------------------
      KAFKA_LOG_DIRS: ${KAFKA_LOG_DIRS}

      # ------------------------------------------------------
      # Broker Configuration
      # ------------------------------------------------------
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: ${KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR}

      KAFKA_AUTO_CREATE_TOPICS_ENABLE: ${KAFKA_AUTO_CREATE_TOPICS_ENABLE}

    networks:
      - infra_msimpl-network

    restart: unless-stopped


  # ==========================================================
  # KAFKA UI
  # ==========================================================
  #
  # Web interface for monitoring and managing the Kafka
  # broker used by Spring Boot applications running from STS.
  #
  kafka-ui:

    image: provectuslabs/kafka-ui

    container_name: kafka-ui

    ports:
      - "8085:8080"

    environment:
      KAFKA_CLUSTERS_0_NAME: Local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092

    depends_on:
      - kafka

    networks:
      - infra_msimpl-network

    restart: unless-stopped


# ==========================================================
# NETWORK CONFIGURATION
# ==========================================================
#
# External Docker bridge network shared by all infrastructure
# containers used during STS-based development.
#
# ==========================================================

networks:

  infra_msimpl-network:
    external: true


