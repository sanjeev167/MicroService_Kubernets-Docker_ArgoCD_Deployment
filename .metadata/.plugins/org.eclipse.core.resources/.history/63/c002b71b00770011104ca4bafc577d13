# ==========================================================
# Service Configuration
# Service: ms-notification
# Author: Sanjeev Kumar
# Date: 2026-06-06
#
# ==========================================================
# 🔒 MSIMPL PHASE 1 ALIGNMENT (LOCKED)
# ==========================================================
#
# This service follows strict Kafka consumption rules:
#
#   ✔ Raw JSON (String) consumption
#   ✔ Manual ObjectMapper parsing in listener
#   ✔ Manual acknowledgment (NO auto commit)
#   ✔ Foundation for Retry + DLQ
#
# 🚫 DO NOT MODIFY Kafka behavior without architectural review
#
# ==========================================================

server:
  port: 8081

spring:
  application:
    name: ms-notification
    
  config:
    import: classpath:application-db.yml

  jpa:
    hibernate:
      ddl-auto: update   # ⚠ Use 'validate' in production
    show-sql: true       # ⚠ Disable in production for performance

  kafka:
    # ------------------------------------------------------
    # Kafka Broker Configuration
    # ------------------------------------------------------
    bootstrap-servers: localhost:29092

    # ======================================================
    # PRODUCER CONFIGURATION (Notification → Orchestrator)
    # ======================================================
    producer:
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.springframework.kafka.support.serializer.JsonSerializer

      # --------------------------------------------------
      # Reliability Guarantees (Producer Side)
      # --------------------------------------------------
      acks: all          # Ensures strongest durability
      retries: 5         # Retry on transient failures

      properties:
        # --------------------------------------------------
        # 🔒 Prevent Type Header Coupling Across Services
        # --------------------------------------------------
        spring.json.add.type.headers: false

    # ======================================================
    # CONSUMER CONFIGURATION (Orchestrator → Notification)
    # ======================================================
    consumer: 

      # --------------------------------------------------
      # 🔒 DESERIALIZATION STRATEGY (LOCKED)
      # --------------------------------------------------
      # Always consume as STRING → manual parsing ONLY
      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      value-deserializer: org.apache.kafka.common.serialization.StringDeserializer

      # --------------------------------------------------
      # 🔴 CRITICAL: OFFSET MANAGEMENT
      # --------------------------------------------------
      enable-auto-commit: false   # MUST remain false

      # --------------------------------------------------
      # Offset Reset Strategy
      # --------------------------------------------------
      auto-offset-reset: earliest # Ensures replay capability

      # --------------------------------------------------
      # 🚫 STRICT RULES
      # --------------------------------------------------
      # - DO NOT use JsonDeserializer
      # - DO NOT enable auto commit
      # - DO NOT rely on Kafka for object mapping
      #
      # ✔ All parsing MUST happen in listener layer

    # ======================================================
    # LISTENER CONFIGURATION
    # ======================================================
    listener:
      concurrency: 1   # Safe default (can be tuned later)

# ==========================================================
# Topic Configuration
# ==========================================================

notification:
  topic:
    request: notification-request-topic
    response: notification-response-topic 

  consumer:
    group-id: notification-saga-request-consumer

# ==========================================================
# 📊 OBSERVABILITY CONFIGURATION (PHASE 2 - NON INTRUSIVE)
# ==========================================================
#
# Technologies:
#   - :contentReference[oaicite:0]{index=0}
#   - :contentReference[oaicite:1]{index=1}
#
# PURPOSE:
#   ✔ Expose application metrics (JVM, HTTP, custom)
#   ✔ Enable Prometheus scraping
#   ✔ Support Grafana dashboards (future phase)
#
# SAFETY:
#   ✔ Read-only endpoints
#   ✔ No impact on Kafka / DB / business logic
#   ✔ No threading or performance side-effects
#
# ==========================================================

management:

  # ------------------------------------------------------
  # Expose Only Required Endpoints (Security + Clarity)
  # ------------------------------------------------------
  endpoints:
    web:
      exposure:
        include: 
          - health        # Service health status
          - info          # Basic service metadata
          - prometheus    # Metrics endpoint for scraping

  # ------------------------------------------------------
  # Health Endpoint Configuration
  # ------------------------------------------------------
  endpoint:
    health:
      show-details: always   # Useful for debugging (restrict in prod)

  # ------------------------------------------------------
  # Metrics Configuration (Micrometer Layer)
  # ------------------------------------------------------
  metrics:
    tags:
      # --------------------------------------------------
      # Global Tag for Service Identification
      # --------------------------------------------------
      # Helps in Grafana filtering across microservices
      application: ${spring.application.name}

  # ------------------------------------------------------
  # Prometheus Export Configuration
  # ------------------------------------------------------
  prometheus:
    metrics:
      export:
        enabled: true   # Enables /actuator/prometheus endpoint

