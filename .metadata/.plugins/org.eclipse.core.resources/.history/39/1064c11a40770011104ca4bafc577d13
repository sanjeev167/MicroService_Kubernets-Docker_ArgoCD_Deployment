# =============================================================================
# File Name   : docker-compose.yml
# Module      : Docker Infrastructure
# Environment : Docker
# Project     : Microservices Platform (MSIMPL)
# Author      : Sanjeev Kumar
# Created On  : 04-Jul-2026
# =============================================================================
#
# Description
# -----------
# Docker infrastructure for the MSIMPL Docker environment.
#
# This compose file provisions the common infrastructure
# required by all MSIMPL microservices executing inside
# Docker containers.
#
# Infrastructure Components
# -------------------------
# • Apache Kafka (KRaft Mode)
# • Kafka UI
#
# Notes
# -----
# PostgreSQL is installed on the Windows host and is NOT
# deployed as a Docker container.
#
# Runtime configuration is externalized into the env folder.
#
# =============================================================================

version: "3.8"

services:

  # ==========================================================
  # APACHE KAFKA (KRaft Mode)
  # ==========================================================
  #
  # Provides the messaging infrastructure for Spring Boot
  # microservices running inside Docker containers.
  #
  kafka:

    image: confluentinc/cp-kafka:7.5.0

    container_name: kafka

    hostname: kafka

    ports:
      - "9092:9092"

    # --------------------------------------------------------
    # Environment Variables
    # --------------------------------------------------------
    #
    # Kafka runtime configuration is centralized in:
    #
    #     env/kafka.env
    #
    # --------------------------------------------------------

    env_file:
      - ./env/kafka.env

    environment:

      # ------------------------------------------------------
      # Static Kafka Configuration
      # ------------------------------------------------------

      KAFKA_PROCESS_ROLES: broker,controller

      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT

      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER

    networks:
      - infra_msimpl-network

    restart: unless-stopped



  # ==========================================================
  # KAFKA UI
  # ==========================================================
  #
  # Web interface for monitoring and managing the Kafka
  # broker used by Dockerized MSIMPL microservices.
  #
  kafka-ui:

    image: provectuslabs/kafka-ui

    container_name: kafka-ui

    hostname: kafka-ui

    ports:
      - "8085:8080"

    environment:

      KAFKA_CLUSTERS_0_NAME: Local

      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092

    depends_on:
      - kafka

    networks:
      - infra_msimpl-network

    restart: unless-stopped



# ==========================================================
# NETWORK CONFIGURATION
# ==========================================================
#
# Shared Docker bridge network used by the infrastructure
# and all MSIMPL Docker containers.
#
# ==========================================================

networks:

  infra_msimpl-network:
    name: infra_msimpl-network
    driver: bridge
    
    