# ==========================================================
# Kafka KRaft Configuration
# ==========================================================
#
# Cluster Identifier
#
# Unique identifier for the Kafka KRaft cluster.
#
# Node Identifier
#
# Unique broker identifier.
#
# Process Roles
#
# Single-node Kafka acts as both Broker and Controller.
#
# Controller Quorum
#
# Defines the controller quorum members.
#
# ==========================================================

CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NODE_ID=1

KAFKA_PROCESS_ROLES=broker,controller

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093


# ==========================================================
# Kafka Listener Configuration
# ==========================================================
#
# PLAINTEXT
# ----------
# Used by Docker containers communicating over the shared
# Docker network.
#
#
# PLAINTEXT_HOST
# --------------
# Used by Spring Boot applications running directly from
# Spring Tool Suite (STS).
#
#
# CONTROLLER
# ----------
# Internal KRaft controller communication.
#
# ==========================================================

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,PLAINTEXT_HOST://0.0.0.0:29092,CONTROLLER://0.0.0.0:9093

KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:29092

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT,CONTROLLER:PLAINTEXT

KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER


# ==========================================================
# Kafka Storage Configuration
# ==========================================================
#
# Directory used by Kafka KRaft to store metadata and
# message log segments.
#
# ==========================================================

KAFKA_LOG_DIRS=/tmp/kraft-combined-logs


# ==========================================================
# Kafka Broker Configuration
# ==========================================================
#
# Offset Topic Replication Factor
#
# Single-node Kafka requires a replication factor of one.
#
#
# Auto Topic Creation
#
# Automatically creates topics during development.
#
# Disable in production.
#
# ==========================================================

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true


